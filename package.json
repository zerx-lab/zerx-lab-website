{
  "name": "zerx-lab-website",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "ZerxLab official website & blog - built with Astro",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "bootstrap": "bun run scripts/bootstrap-directus.ts",
    "seed": "bun run scripts/seed-directus.ts",
    "typegen": "bun run scripts/generate-directus-types.ts",
    "lint": "astro check",
    "format": "prettier --write \"**/*.{astro,ts,tsx,md,mdx,json}\""
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.1",
    "@astrojs/react": "^4.2.1",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.2.1",
    "@directus/sdk": "^21.2.2",
    "@tailwindcss/vite": "^4.1.3",
    "astro": "^6.1.7",
    "marked": "^18.0.1",
    "marked-shiki": "^1.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.3"
  }
}
