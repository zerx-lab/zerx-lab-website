---
/**
 * ============================================================================
 * 博客详情页 (中文,默认无前缀)
 * ----------------------------------------------------------------------------
 * 路由:
 *   /blog/:slug        → 本文件(zh)
 *   /en/blog/:slug     → src/pages/en/blog/[slug].astro(英文)
 *
 * 实现(SSR):
 *   - 全站 `output: "server"`,本路由按请求实时渲染
 *   - 页面级预检:先用 loadPostBySlug 判断 slug 是否存在
 *     · 不存在 → Astro.redirect("/404", 404),由 src/pages/404.astro 渲染自定义 404
 *     · 存在   → 交给 BlogPostPage 组件走完整渲染流程
 *   - 缓存策略由 src/middleware.ts 统一下发 Cache-Control,本文件不关心
 *
 * 为什么在页面级做 404 判断而不是交给子组件 return Response:
 *   Astro 的 `.astro` 组件(非页面)里 return Response 行为未定义,
 *   会触发 "The response has already been sent" 的 ResponseSentError。
 *   只有页面文件顶层的 return Astro.redirect(...) / return new Response(...)
 *   才是可靠的终止渲染方式。
 *
 *   代价:slug 有效时 loadPostBySlug 会在页面和组件里各跑一次。
 *   由于每次查询都走 Directus(同一 HTTP/2 连接可复用),开销可接受,
 *   且能获得正确的 HTTP 状态码与 middleware 缓存语义。
 *
 * 为什么不再用 getStaticPaths:
 *   切到 SSR 之后,动态路由由运行时解析 slug,不再需要构建期枚举。
 *   原本的 listPublishedPostSlugs() 只保留给 sitemap / RSS 等需要枚举的场景。
 *
 * 维护约定:
 *   页面结构 / 数据拉取 / 正文渲染都在 BlogPostPage.astro,
 *   本文件只负责:取 slug → 存在性判断 → 404 跳转或转交。
 * ============================================================================
 */

import BlogPostPage from "@components/blog/BlogPostPage.astro";
import { loadPostBySlug } from "@lib/queries/posts";
import { getLangFromUrl } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

const { slug } = Astro.params;

// 类型收窄兜底:Astro 不会在没有 slug 的情况下匹配到 [slug].astro,
// 这里仅为防御式编程。
if (!slug) {
	return Astro.redirect("/404", 404);
}

// 页面级预检:slug 不存在则走 404 页面。
// 注意传 lang 仅影响返回 PostVM 的字段语言,不影响"是否命中"的判定。
const lang = getLangFromUrl(Astro.url) as Lang;
const post = await loadPostBySlug(slug, lang);

if (!post) {
	return Astro.redirect("/404", 404);
}
---

<BlogPostPage slug={slug} />
