/**
 * ============================================================================
 * AUR 页 (英文)
 * ----------------------------------------------------------------------------
 * 路由:
 *   /en/aur  → 本文件(en)
 *   /aur     → src/pages/aur.astro(默认中文,无前缀)
 *
 * 实现:
 *   与中文版完全同构,共用 AurPage 组件。
 *   AurPage 内部通过 getLangFromUrl(Astro.url) 推断当前语言,
 *   URL 以 /en/ 开头时自动输出英文文案与英文包描述。
 *
 * 数据源:
 *   - Directus aur_packages 集合(已 bootstrap 时)
 *   - 失败/未 bootstrap 时自动 fallback 到 src/lib/fallback-data.ts
 *
 * 维护约定:
 *   若要修改 AUR 页的结构/样式/数据拉取逻辑,只改
 *   src/components/aur/AurPage.astro,本文件与中文入口都会受益。
 * ============================================================================
 */

import AurPage from "@components/aur/AurPage.astro";
---

<AurPage />
