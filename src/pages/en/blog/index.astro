 *
 * 维护约定:
 *   若要修改博客列表的结构/样式/数据拉取逻辑,只改
 *   src/components/blog/BlogIndexPage.astro,本文件与中文入口都会受益。
 * ============================================================================
 */

import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
