---
/**
 * ============================================================================
 * LabMark - 实验室视觉装置(ASCII 几何图 + 宣言)
 * ----------------------------------------------------------------------------
 * 用途:
 *   左栏 Logo 与标题之间的大片留白区域,用此组件填充视觉装置。
 *   不是代码块、不是插画,而是一段"纯字符几何 + 编辑派宣言"的组合 ——
 *   最贴合 ZerxLab 品牌(极简/工程/编辑派)同时与右栏代码块形成互补。
 *
 * 视觉组成(由上至下):
 *   1. 顶栏 meta 行:MARK • 01  + 右侧 ∎ / ZERX-LAB
 *   2. ASCII 几何图案(由 █▓▒░ 字符拼出的"模块堆栈"矩阵)
 *   3. 细虚线分割
 *   4. § MANIFESTO 眉标
 *   5. 三行短宣言 (衬线或无衬线大字)
 *   6. 落款 — ZerxLab, est. 2020
 *
 * 设计约束:
 *   - 不依赖任何图片/SVG/字体图标,所有视觉来自字符和 CSS 边框
 *   - 暗色/亮色模式自动适配(靠 var 映射)
 *   - 响应式:移动端(< 1024px)装置会略微缩小,大屏保持不变
 *   - 纯静态,零 JS
 *
 * 用法:
 *   默认渲染 ZerxLab 预设装置:
 *     <LabMark />
 *
 *   自定义宣言文案:
 *     <LabMark
 *       manifestoLines={["Build fast.", "Ship open.", "Stay curious."]}
 *       signature="— ZerxLab, est. 2020"
 *     />
 *
 *   自定义 mark 编号(如在不同页面显示 02/03...作为"本页序号"):
 *     <LabMark markNumber="03" />
 *
 *   如果某些页面只想要一种元素,可用 only="ascii" / only="manifesto" 裁剪:
 *     <LabMark only="manifesto" />
 * ============================================================================
 */

import { getLangFromUrl } from "@i18n/utils";

interface Props {
	/** 顶栏显示的编号标签,默认 "01" */
	markNumber?: string;
	/** 宣言三行文案(每行建议 ≤ 14 字符,保持视觉紧凑) */
	manifestoLines?: readonly string[];
	/** 落款文字(宣言下方一行) */
	signature?: string;
	/** 只展示某一部分 */
	only?: "all" | "ascii" | "manifesto";
	/** 额外类名 */
	class?: string;
}

const lang = getLangFromUrl(Astro.url);

// 默认宣言按语言切换;刻意用极短三词一行的格式,和右栏 FEATURES 卡片标题语气一致
const defaultManifesto: Record<"zh" | "en", readonly string[]> =
	{
		zh: ["构建要快。", "开源要真。", "好奇常在。"] as const,
		en: ["Build fast.", "Ship open.", "Stay curious."] as const,
	};

const defaultSignature: Record<"zh" | "en", string> = {
	zh: "— ZerxLab,始于 2020",
	en: "— ZerxLab, est. 2020",
};

const {
	markNumber = "01",
	manifestoLines = defaultManifesto[lang],
	signature = defaultSignature[lang],
	only = "all",
	class: className = "",
} = Astro.props;

const showAscii = only === "all" || only === "ascii";
const showManifesto = only === "all" || only === "manifesto";

/* ----------------------------------------------------------------------------
 * ASCII 几何矩阵
 * ----------------------------------------------------------------------------
 * 设计意图:"由堆叠的小模块组成的实验室"
 *   - 使用 4 档灰度字符 █ ▓ ▒ ░ 制造景深
 *   - 左上浓、右下淡,形成一条隐含的"光源"对角线
 *   - 尺寸 5 行 × 11 列,视觉上近似正方形(字符宽高比约 0.55)
 *
 * 每行严格等长,避免参差;字符间空格用于呼吸感。
 * -------------------------------------------------------------------------- */

const ASCII_MATRIX: readonly string[] = [
	"█ █ █ █ ▓ ▓ ▒ ▒ ▒ ░ ░",
	"█ █ ▓ ▓ ▓ ▒ ▒ ▒ ░ ░ ·",
	"█ ▓ ▓ ▒ ▒ ▒ ░ ░ · · ·",
	"▓ ▓ ▒ ▒ ░ ░ · · · · ·",
	"▓ ▒ ░ ░ · · · · · · ·",
] as const;
---

<div
	class:list={[
		"lab-mark",
		"relative",
		"select-none",
		className,
	]}
	aria-hidden="true"
>
	{/* ---------- 顶栏 meta:MARK · 编号 + 右侧标签 ---------- */}
	<div
		class:list={[
			"flex items-center justify-between",
			"mb-3 lg:mb-4",
		]}
	>
		<div class="flex items-center gap-2">
			<span
				class:list={[
					"mono-label",
					"text-[10px]",
					"leading-none",
					"text-[color:var(--color-ink-tertiary)]",
				]}>MARK</span>
			<span
				aria-hidden="true"
				class:list={[
					"inline-block w-6 h-px",
					"bg-[color:var(--color-hairline-strong)]",
				]}></span>
			<span
				class:list={[
					"mono-num",
					"text-[10px]",
					"tabular-nums",
					"text-[color:var(--color-ink-muted)]",
				]}>{markNumber}</span>
		</div>

		<div class="flex items-center gap-1.5">
			<span
				aria-hidden="true"
				class:list={[
					"inline-block h-[6px] w-[6px]",
					"bg-[color:var(--color-ink-primary)]",
				]}></span>
			<span
				class:list={[
					"mono-label",
					"text-[10px]",
					"leading-none",
					"text-[color:var(--color-ink-tertiary)]",
				]}>ZERX-LAB</span>
		</div>
	</div>

	{/* ---------- ASCII 几何矩阵(核心视觉) ---------- */}
	{
		showAscii && (
			<div
				class:list={[
					"ascii-box",
					"relative",
					"px-4 py-5 lg:px-5 lg:py-6",
					"border border-dashed border-[color:var(--color-hairline)]",
					"bg-[color:var(--color-paper-muted)]/30",
					"rounded-[var(--radius-sm)]",
					"overflow-hidden",
				]}
			>
				{/* 四角的极小锚点(编辑派小细节) */}
				<span class="corner corner-tl" aria-hidden="true" />
				<span class="corner corner-tr" aria-hidden="true" />
				<span class="corner corner-bl" aria-hidden="true" />
				<span class="corner corner-br" aria-hidden="true" />

				<pre
					class:list={[
						"ascii-pre",
						"font-[var(--font-mono)]",
						"text-[color:var(--color-ink-secondary)]",
						// 字符大小:大屏稍紧凑,确保左栏宽度容纳不溢出
						"text-[12px] sm:text-[12.5px] lg:text-[12px] xl:text-[12.5px]",
						"leading-[1.7]",
						"tracking-[0.02em]",
						"m-0",
						"whitespace-pre",
						"text-center",
					]}>{ASCII_MATRIX.join("\n")}</pre>

				{/* 底栏:左"模块计数",右"状态 dot" */}
				<div
					class:list={[
						"mt-4 pt-3",
						"border-t border-dashed border-[color:var(--color-hairline)]",
						"flex items-center justify-between",
						"font-[var(--font-mono)]",
						"text-[10px]",
						"tracking-[var(--tracking-wide)]",
						"text-[color:var(--color-ink-tertiary)]",
					]}
				>
					<span class="uppercase tabular-nums">
						55 modules
					</span>
					<span class="flex items-center gap-1.5">
						<span
							aria-hidden="true"
							class:list={[
								"inline-block h-[6px] w-[6px] rounded-full",
								"bg-[color:var(--color-ink-primary)]",
								"lab-mark-pulse",
							]}></span>
						<span class="uppercase">online</span>
					</span>
				</div>
			</div>
		)
	}

	{/* ---------- 宣言区 ---------- */}
	{
		showManifesto && (
			<div
				class:list={[
					showAscii ? "mt-7 lg:mt-8" : "mt-0",
				]}
			>
				{/* 分节符号 */}
				<div
					class:list={[
						"flex items-center gap-2",
						"mb-4",
					]}
				>
					<span
						aria-hidden="true"
						class:list={[
							"font-[var(--font-serif)]",
							"text-[14px] leading-none",
							"text-[color:var(--color-ink-muted)]",
						]}>§</span>
					<span
						class:list={[
							"mono-label",
							"text-[10px] leading-none",
							"tracking-[var(--tracking-wider)]",
							"text-[color:var(--color-ink-tertiary)]",
						]}>{lang === "zh" ? "宣言" : "MANIFESTO"}</span>
					<span
						aria-hidden="true"
						class:list={[
							"flex-1 h-px",
							"bg-transparent",
							"border-t border-dashed border-[color:var(--color-hairline)]",
						]}></span>
				</div>

				{/* 宣言三行 */}
				<div
					class:list={[
						"flex flex-col gap-[2px]",
						"text-[color:var(--color-ink-primary)]",
						"leading-[1.25]",
						"tracking-[-0.01em]",
						// 响应式字号:略大于正文,小于页面主 H1
						"text-[18px] sm:text-[19px] lg:text-[20px] xl:text-[22px]",
						"font-medium",
					]}
				>
					{
						manifestoLines.map((line: string, idx: number) => (
							<p class="manifesto-line" style={`--i:${idx}`}>
								{line}
							</p>
						))
					}
				</div>

				{/* 落款 */}
				{
					signature && (
						<p
							class:list={[
								"mt-4",
								"font-[var(--font-mono)]",
								"text-[11px]",
								"tracking-[var(--tracking-wide)]",
								"text-[color:var(--color-ink-muted)]",
							]}
						>
							{signature}
						</p>
					)
				}
			</div>
		)
	}
</div>

<style>
	/* ----------------------------------------------------------------------------
	 * ASCII 盒子的四角锚点 ——
	 * 在盒子四个角落的外侧加两条极短的实线,像技术图纸的"裁切标记"。
	 * 这是编辑派/工程制图常见的细节,放大到左栏装置上增强质感。
	 * -------------------------------------------------------------------------- */

	.corner {
		position: absolute;
		width: 8px;
		height: 8px;
		pointer-events: none;
		color: var(--color-ink-primary);
	}

	.corner-tl {
		top: -1px;
		left: -1px;
		border-top: 1px solid currentColor;
		border-left: 1px solid currentColor;
	}

	.corner-tr {
		top: -1px;
		right: -1px;
		border-top: 1px solid currentColor;
		border-right: 1px solid currentColor;
	}

	.corner-bl {
		bottom: -1px;
		left: -1px;
		border-bottom: 1px solid currentColor;
		border-left: 1px solid currentColor;
	}

	.corner-br {
		bottom: -1px;
		right: -1px;
		border-bottom: 1px solid currentColor;
		border-right: 1px solid currentColor;
	}

	/* ----------------------------------------------------------------------------
	 * ASCII 矩阵容器
	 * --------------------------------------------------------------------------
	 * - 在暗色模式下,字符颜色通过 var 自动反相
	 * - 使用 font-feature "tnum" 强制等宽数字对齐(虽然此处无数字,留作未来)
	 * -------------------------------------------------------------------------- */

	.ascii-pre {
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum" 1, "ss01" 1;
		/* 防止父容器 body 的 text-rendering 把 ▓▒ 优化成诡异字形 */
		text-rendering: optimizeSpeed;
	}

	/* ----------------------------------------------------------------------------
	 * Online 状态 dot 的轻微脉动
	 * --------------------------------------------------------------------------
	 * 极其低调的呼吸动画,只在允许动效时展示;
	 * 如果用户设置了 prefers-reduced-motion,直接禁用,由 global.css 兜底。
	 * -------------------------------------------------------------------------- */

	.lab-mark-pulse {
		animation: lab-mark-breathe 2400ms ease-in-out infinite;
	}

	@keyframes lab-mark-breathe {
		0%,
		100% {
			opacity: 1;
			transform: scale(1);
		}
		50% {
			opacity: 0.35;
			transform: scale(0.8);
		}
	}

	/* ----------------------------------------------------------------------------
	 * 宣言每行的入场(极轻,仅首次加载有感)
	 * --------------------------------------------------------------------------
	 * 依次由上至下淡入,--i 索引做错峰;
	 * 不影响 SSR 首屏完整性(transform 初始值极小,失败也看得见内容)。
	 * -------------------------------------------------------------------------- */

	.manifesto-line {
		opacity: 0;
		transform: translateY(4px);
		animation: lab-mark-fade-in 420ms var(--ease-standard, cubic-bezier(0.4, 0, 0.2, 1)) forwards;
		animation-delay: calc(80ms * var(--i, 0) + 120ms);
		margin: 0;
	}

	@keyframes lab-mark-fade-in {
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ----------------------------------------------------------------------------
	 * 可达性:尊重 reduced-motion
	 * -------------------------------------------------------------------------- */

	@media (prefers-reduced-motion: reduce) {
		.lab-mark-pulse {
			animation: none;
		}

		.manifesto-line {
			opacity: 1;
			transform: none;
			animation: none;
		}
	}
</style>
