---
/**
 * ============================================================================
 * AurPage - AUR 软件包列表页共享组件
 * ----------------------------------------------------------------------------
 * 为什么抽成独立组件:
 *   中文 /aur 与英文 /en/aur 两个入口页面 95% 的逻辑相同,
 *   只有语言推导与少量默认文案不同。本组件负责:
 *     1. 从 Directus 拉取 aur_packages(失败时 fallback)
 *     2. 把 Bilingual 字段按当前 lang 解包
 *     3. 顶部展示"一行安装命令"示例(yay / paru 双 tab)
 *     4. 列表展示每个包,带 badges、版本、上游/AUR 链接、复制安装命令
 *
 * 视觉策略(参考 Vercel 历史博客的 AUR 展示 + better-auth 编辑派):
 *   - 顶部"快速安装"卡片:带 tab 切换(yay / paru)+ 命令行 + 复制按钮
 *   - 每包一张横向卡片:
 *       [左] 包名 + badges + 版本标签
 *       [中] 描述
 *       [右] AUR_PAGE / UPSTREAM 两个小链接 + 复制安装命令按钮
 *   - 虚线分隔 + Monospace 标签 + 编号前缀,整体与项目页视觉一致
 *
 * 左栏 meta 字段说明:
 *   - PACKAGES    包总数
 *   - MAINTAINED  维护中的包数
 *   - DISTRO      Arch Linux
 *   - HELPER      yay / paru
 * ============================================================================
 */

import AppShell from "@layouts/AppShell.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import MetaRow from "@components/ui/MetaRow.astro";
import {
	getLangFromUrl,
	useTranslations,
} from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import {
	listFallbackAurPackages,
	pickLang,
	type FallbackAurPackage,
} from "@lib/fallback-data";
import { directus, readItems, DIRECTUS_CONFIG } from "@lib/directus";

/* ----------------------------------------------------------------------------
 * 当前语言 / 翻译工具
 * -------------------------------------------------------------------------- */

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

/* ----------------------------------------------------------------------------
 * 数据适配器
 * -------------------------------------------------------------------------- */

interface AurVM {
	slug: string;
	name: string;
	version: string;
	description: string;
	badges: readonly string[];
	aurUrl: string;
	upstreamUrl: string | null;
	maintained: boolean;
}

function fallbackToVM(pkg: FallbackAurPackage, currentLang: Lang): AurVM {
	return {
		slug: pkg.slug,
		name: pkg.name,
		version: pkg.version,
		description: pickLang(pkg.description, currentLang),
		badges: pkg.badges,
		aurUrl: pkg.aurUrl,
		upstreamUrl: pkg.upstreamUrl,
		maintained: pkg.maintained,
	};
}

/* ----------------------------------------------------------------------------
 * 尝试从 Directus 拉取,失败则走 Fallback
 * -------------------------------------------------------------------------- */

async function loadPackages(): Promise<readonly AurVM[]> {
	if (!DIRECTUS_CONFIG.hasReadToken) {
		return listFallbackAurPackages().map((p) => fallbackToVM(p, lang));
	}

	try {
		const client = directus();
		const langCode = lang === "zh" ? "zh-CN" : "en-US";

		const pkgFields: any = [
			"id",
			"name",
			"version",
			"maintained",
			"badges",
			"aur_url",
			"upstream_url",
			"sort",
			{
				translations: ["languages_code", "description"],
			},
		];

		const result = (await client.request(
			readItems("aur_packages", {
				filter: { status: { _eq: "published" } },
				sort: ["sort", "name"],
				fields: pkgFields,
				limit: -1,
			}),
		)) as any[];

		return result.map((row): AurVM => {
			const tr = row?.translations?.find(
				(x: any) =>
					x.languages_code === langCode ||
					x.languages_code?.code === langCode,
			);

			const badges: readonly string[] = Array.isArray(row?.badges)
				? row.badges
				: [];

			// slug 从包名派生(去掉 zerx-lab- 前缀和 -bin 后缀)
			const rawName = row?.name ?? "";
			const slug = rawName
				.replace(/^zerx-lab-/, "")
				.replace(/-bin$/, "");

			return {
				slug,
				name: rawName,
				version: row?.version ?? "—",
				description: tr?.description ?? "",
				badges,
				aurUrl: row?.aur_url ?? "",
				upstreamUrl: row?.upstream_url ?? null,
				maintained: row?.maintained !== false,
			};
		});
	} catch (err) {
		console.warn(
			"[aur] Directus 读取失败,使用 FALLBACK。原因:",
			(err as Error)?.message ?? err,
		);
		return listFallbackAurPackages().map((p) => fallbackToVM(p, lang));
	}
}

const packages = await loadPackages();

/* ----------------------------------------------------------------------------
 * 左栏 meta 数据计算
 * -------------------------------------------------------------------------- */

const maintainedCount = packages.filter((p) => p.maintained).length;

/* ----------------------------------------------------------------------------
 * 页面级文案
 * -------------------------------------------------------------------------- */

const COPY = {
	zh: {
		eyebrow: "AUR",
		title: "AUR 软件包",
		description:
			"为 Arch Linux 用户维护的 AUR 软件包。所有包都以预编译二进制方式分发,一行命令即装即用。",
		empty: "暂无包。",
		sectionQuickInstall: "QUICK INSTALL",
		sectionAllPackages: "ALL PACKAGES",
		aurPage: "AUR 页面",
		upstream: "官网",
		installCmd: "安装命令",
		copyCmd: "复制",
		copiedCmd: "已复制",
		maintained: "维护中",
		deprecated: "已弃用",
		version: "版本",
		helperNote:
			"提示:以下命令假设你已安装 AUR 助手(yay / paru)。未安装时请参考 Arch Wiki。",
		distroLabel: "发行版",
		helperLabel: "助手",
		packagesLabel: "软件包",
		maintainedLabel: "维护中",
	},
	en: {
		eyebrow: "AUR",
		title: "AUR Packages",
		description:
			"AUR packages maintained for Arch Linux users. All shipped as prebuilt binaries — one command to install.",
		empty: "No packages yet.",
		sectionQuickInstall: "QUICK INSTALL",
		sectionAllPackages: "ALL PACKAGES",
		aurPage: "AUR Page",
		upstream: "Website",
		installCmd: "Install command",
		copyCmd: "Copy",
		copiedCmd: "Copied",
		maintained: "Maintained",
		deprecated: "Deprecated",
		version: "Version",
		helperNote:
			"Note: commands below assume an AUR helper (yay / paru) is installed. See Arch Wiki otherwise.",
		distroLabel: "Distro",
		helperLabel: "Helper",
		packagesLabel: "Packages",
		maintainedLabel: "Maintained",
	},
} as const;

const C = COPY[lang] ?? COPY.zh;

/* ----------------------------------------------------------------------------
 * 快速安装:生成"安装全部"命令示例
 * ----------------------------------------------------------------------------
 * 选中全部已维护的包名,拼成一条命令,两种 helper 各生成一条。
 * 在 tab 切换时分别展示,带"复制"按钮。
 * -------------------------------------------------------------------------- */

const maintainedNames = packages
	.filter((p) => p.maintained && p.name)
	.map((p) => p.name);

const yayInstall = maintainedNames.length
	? `yay -S ${maintainedNames.join(" ")}`
	: "yay -S zerx-lab-pencil-bin";

const paruInstall = maintainedNames.length
	? `paru -S ${maintainedNames.join(" ")}`
	: "paru -S zerx-lab-pencil-bin";
---

