<style>
	/* ----------------------------------------------------------------------------
	 * Tab 激活态:靠 aria-selected 驱动
	 * --------------------------------------------------------------------------
	 * 激活的 Tab 有一条底部墨色实线锚点,非激活态仅为淡灰色标签。
	 * -------------------------------------------------------------------------- */

	.install-tab {
		position: relative;
	}

	.install-tab[aria-selected="true"]::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: -1px;
		height: 2px;
		background-color: var(--color-ink-primary);
	}

	/* Tab 面板默认不显示,JS 切换时移除 hidden 属性 */
	.install-panel[hidden] {
		display: none;
	}

	/* ----------------------------------------------------------------------------
	 * 复制按钮的"已复制"态
	 * --------------------------------------------------------------------------
	 * 通过 data-copied="true" 切换视觉反馈,~2s 后自动还原。
	 * -------------------------------------------------------------------------- */

	.copy-btn[data-copied="true"] {
		color: var(--color-ink-primary);
		background-color: var(--color-paper-muted);
		border-color: var(--color-hairline-strong);
	}
</style>

<script>
	/**
	 * =========================================================================
	 * AurPage 交互脚本
	 * -------------------------------------------------------------------------
	 * 负责:
	 *   1. 快速安装区的 yay / paru tab 切换
	 *   2. 所有 [data-copy-btn] 的复制到剪贴板功能
	 *
	 * 兼容性:
	 *   - Astro View Transitions:astro:after-swap 时重新绑定
	 *   - 不依赖框架;纯 TS + DOM API
	 * ========================================================================= */

	interface AurController {
		destroy(): void;
	}

	function setupInstallTabs(root: HTMLElement): () => void {
		const tabs = Array.from(
			root.querySelectorAll<HTMLButtonElement>("[data-install-tab]"),
		);
		const panels = Array.from(
			root.querySelectorAll<HTMLElement>("[data-install-panel]"),
		);

		function activate(name: string): void {
			for (const tab of tabs) {
				const isActive = tab.getAttribute("data-install-tab") === name;
				tab.setAttribute("aria-selected", String(isActive));
			}
			for (const panel of panels) {
				const isActive =
					panel.getAttribute("data-install-panel") === name;
				if (isActive) {
					panel.removeAttribute("hidden");
				} else {
					panel.setAttribute("hidden", "");
				}
			}
		}

		function onClick(e: Event): void {
			const target = e.target as HTMLElement | null;
			if (!target) return;
			const tab = target.closest<HTMLButtonElement>("[data-install-tab]");
			if (!tab) return;
			const name = tab.getAttribute("data-install-tab");
			if (!name) return;
			activate(name);
		}

		root.addEventListener("click", onClick);

		return () => {
			root.removeEventListener("click", onClick);
		};
	}

	async function copyToClipboard(text: string): Promise<boolean> {
		if (!text) return false;
		try {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(text);
				return true;
			}
			// 降级:老方案,隐藏 textarea + execCommand
			const ta = document.createElement("textarea");
			ta.value = text;
			ta.setAttribute("readonly", "");
			ta.style.position = "fixed";
			ta.style.top = "-1000px";
			ta.style.left = "-1000px";
			document.body.appendChild(ta);
			ta.select();
			const ok = document.execCommand("copy");
			document.body.removeChild(ta);
			return ok;
		} catch {
			return false;
		}
	}

	function setupCopyButtons(): () => void {
		const buttons = Array.from(
			document.querySelectorAll<HTMLButtonElement>("[data-copy-btn]"),
		);

		function swapLabel(btn: HTMLButtonElement, toCopied: boolean): void {
			const labelEl = btn.querySelector<HTMLElement>("[data-copy-label]");
			if (!labelEl) return;
			const def = labelEl.getAttribute("data-default-label") ?? "Copy";
			const copied =
				labelEl.getAttribute("data-copied-label") ?? "Copied";
			labelEl.textContent = toCopied ? copied : def;
			if (toCopied) {
				btn.setAttribute("data-copied", "true");
			} else {
				btn.removeAttribute("data-copied");
			}
		}

		const timers = new WeakMap<HTMLButtonElement, number>();

		async function onClick(this: HTMLButtonElement): Promise<void> {
			const text = this.getAttribute("data-copy-text") ?? "";
			const ok = await copyToClipboard(text);
			if (!ok) return;

			swapLabel(this, true);

			// 已有计时器时先清理,避免多次点击覆盖
			const existing = timers.get(this);
			if (existing) window.clearTimeout(existing);

			const id = window.setTimeout(() => {
				swapLabel(this, false);
				timers.delete(this);
			}, 1600);
			timers.set(this, id);
		}

		for (const btn of buttons) {
			btn.addEventListener("click", onClick);
		}

		return () => {
			for (const btn of buttons) {
				btn.removeEventListener("click", onClick);
			}
		};
	}

	let cleanups: Array<() => void> = [];

	function setup(): AurController {
		// 清理上一次的监听
		for (const fn of cleanups) fn();
		cleanups = [];

		const root = document.querySelector<HTMLElement>(
			"[data-install-tabs]",
		);
		if (root) {
			cleanups.push(setupInstallTabs(root));
		}
		cleanups.push(setupCopyButtons());

		return {
			destroy(): void {
				for (const fn of cleanups) fn();
				cleanups = [];
			},
		};
	}

	// 首次加载
	setup();

	// Astro View Transitions 兼容:每次页面切换后重新绑定
	document.addEventListener("astro:after-swap", setup);
</script>
