---
/**
 * ============================================================================
 * BlogPostPage - 博客详情页共享组件
 * ----------------------------------------------------------------------------
 * 为什么抽成独立组件:
 *   中文 /blog/[slug] 与英文 /en/blog/[slug] 两个动态路由入口复用完全相同
 *   的渲染逻辑。本组件负责:
 *     1. 按 slug 从 Directus / Fallback 拉取单篇文章
 *     2. 把 Bilingual 字段按当前 lang 解包
 *     3. 渲染 Markdown 正文(含 TOC 抽取、Shiki 代码高亮、字数统计)
 *     4. 组合左栏(文章 meta)与右栏(正文 + TOC + 上一篇/下一篇)
 *
 * 左栏信息布局:
 *   - 覆盖默认 LabMark,改为展示文章 meta 卡片
 *   - AUTHOR / PUBLISHED / UPDATED / CATEGORY / READING TIME / TAGS
 *   - 底部额外一行"回到博客列表"导航
 *
 * 右栏信息布局:
 *   - BLOG · slug 面包屑
 *   - 文章标题 + excerpt
 *   - TOC(仅当文章有 H2/H3 时显示)
 *   - Markdown 正文(prose 样式)
 *   - 分割线 + 上一篇 / 下一篇导航
 *
 * 使用方式(页面文件,SSR):
 *   ---
 *   import BlogPostPage from "@components/blog/BlogPostPage.astro";
 *   const { slug } = Astro.params;
 *   if (!slug) return new Response(null, { status: 404 });
 *   ---
 *   <BlogPostPage slug={slug} />
 *
 * 错误处理:
 *   - slug 不存在 → 直接 return 404 Response(运行时由 loadPostBySlug 判定)
 *   - Markdown 渲染失败 → 降级为纯文本 <pre>,不让页面炸
 * ============================================================================
 */

import AppShell from "@layouts/AppShell.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import MetaRow from "@components/ui/MetaRow.astro";
import TableOfContents from "@components/blog/TableOfContents.astro";
import Logo from "@components/ui/Logo.astro";
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
	formatDate,
	formatDateCompact,
} from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import {
	loadPostBySlug,
	loadAdjacentPosts,
	type PostVM,
} from "@lib/queries/posts";
import { renderMarkdown, type MarkdownHeading } from "@lib/markdown";
import "@styles/prose.css";

interface Props {
	/** 文章 slug(来自 dynamic route 的 Astro.params.slug) */
	slug: string;
}

const { slug } = Astro.props;

/* ----------------------------------------------------------------------------
 * 当前语言 / 翻译工具
 * -------------------------------------------------------------------------- */

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

/* ----------------------------------------------------------------------------
 * 加载文章
 * ----------------------------------------------------------------------------
 * 所有数据源优先级、fallback 降级、Directus fields 映射都收敛在
 * src/lib/queries/posts.ts,本文件只消费 PostVM。
 *
 * 三层优先级(由 loadPostBySlug 内部处理):
 *   1. Directus posts + translations + author + category + tags
 *   2. fallback-data 的 FALLBACK_POSTS
 *   3. 都找不到 → null
 *
 * 404 边界在页面文件(src/pages/blog/[slug].astro 与 /en/blog/[slug].astro)
 * 已经前置拦截:slug 查不到时页面直接 Astro.redirect("/404", 404),
 * 根本不会渲染到本组件。本组件里若仍然拿到 null 属于"契约被破坏"的 bug,
 * 应当抛错而不是 return Response —— Astro 的 `.astro` 子组件里
 * return Response 行为未定义,会触发 ResponseSentError。
 * -------------------------------------------------------------------------- */

const post: PostVM | null = await loadPostBySlug(slug, lang);

if (!post) {
	// 理论上不可达:页面层已前置拦截 null 情况。若真的走到这里,
	// 说明调用方没按契约使用本组件,直接抛错便于排查而不是静默降级。
	throw new Error(
		`[BlogPostPage] loadPostBySlug("${slug}") returned null. ` +
			`调用方应在页面级先做存在性判断并跳转 404,不应把不存在的 slug 传进本组件。`,
	);
}

/* ----------------------------------------------------------------------------
 * 相邻文章(上一篇/下一篇)
 * -------------------------------------------------------------------------- */

const { previous: prevVM, next: nextVM } = await loadAdjacentPosts(slug, lang);

/* ----------------------------------------------------------------------------
 * Markdown 渲染
 * ----------------------------------------------------------------------------
 * 失败兜底:渲染失败时降级为转义后的 <pre>,保证文章页永远能打开。
 * -------------------------------------------------------------------------- */

let renderedHtml = "";
let headings: readonly MarkdownHeading[] = [];
let wordCount = 0;
let readingTimeMin = post.readingTime;

try {
	const result = await renderMarkdown(post.content);
	renderedHtml = result.html;
	headings = result.headings;
	wordCount = result.wordCount;
	// 以实际字数推算的阅读时长优先,fallback 到数据字段
	if (result.readingTimeMin > 0) {
		readingTimeMin = result.readingTimeMin;
	}
} catch (err) {
	console.warn(
		`[blog/${slug}] Markdown 渲染失败,降级为纯文本。原因:`,
		(err as Error)?.message ?? err,
	);
	const escaped = post.content
		.replace(/&/g, "&amp;")
		.replace(/</g, "&lt;")
		.replace(/>/g, "&gt;");
	renderedHtml = `<pre>${escaped}</pre>`;
}

/* ----------------------------------------------------------------------------
 * 页面级文案
 * -------------------------------------------------------------------------- */

const COPY = {
	zh: {
		blogBreadcrumb: "博客",
		backToList: "返回博客列表",
		prev: "上一篇",
		next: "下一篇",
		words: "字",
		author: "作者",
		published: "发布于",
		updated: "更新于",
		category: "分类",
		readingTime: "阅读时长",
		tags: "标签",
		minutes: "分钟",
		viewAuthor: "查看作者主页",
	},
	en: {
		blogBreadcrumb: "Blog",
		backToList: "Back to all posts",
		prev: "Previous",
		next: "Next",
		words: "words",
		author: "Author",
		published: "Published",
		updated: "Updated",
		category: "Category",
		readingTime: "Reading time",
		tags: "Tags",
		minutes: "min",
		viewAuthor: "View author",
	},
} as const;

const C = COPY[lang] ?? COPY.zh;

/* ----------------------------------------------------------------------------
 * 结构化数据(JSON-LD)—— BlogPosting
 * ----------------------------------------------------------------------------
 * 提升搜索引擎对博客内容的理解。仅在文章有作者与日期时生成。
 * -------------------------------------------------------------------------- */

const siteUrl = (import.meta.env.SITE ?? "https://zerx.dev").replace(
	/\/$/,
	"",
);
const canonical = `${siteUrl}${Astro.url.pathname}`;

const jsonLd = JSON.stringify({
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: post.title,
	description: post.excerpt,
	url: canonical,
	datePublished: post.date,
	dateModified: post.updatedDate ?? post.date,
	author: post.authorName
		? {
				"@type": "Person",
				name: post.authorName,
				url: post.authorGithub ?? undefined,
			}
		: undefined,
	publisher: {
		"@type": "Organization",
		name: "ZerxLab",
		url: siteUrl,
	},
	mainEntityOfPage: {
		"@type": "WebPage",
		"@id": canonical,
	},
	inLanguage: lang === "zh" ? "zh-CN" : "en-US",
	wordCount,
});
---

<AppShell
	title={post.title}
	description={post.excerpt}
	ogType="article"
	articlePublishedTime={post.date}
	articleModifiedTime={post.updatedDate ?? undefined}
	articleAuthor={post.authorName ?? undefined}
	maxContentWidth="none"
>
	{/* ---------- 在 head 注入 BlogPosting JSON-LD ---------- */}
	<Fragment slot="head">
		<script
			type="application/ld+json"
			is:inline
			set:html={jsonLd}
		/>
	</Fragment>

	{/* ---------- 左栏:完全自定义(覆盖默认 LabMark) ---------- */}
	<Fragment slot="left">
		<aside
			class:list={[
				"relative flex flex-col",
				"bg-[color:var(--color-paper)]",
				"lg:border-r lg:border-dashed lg:border-[color:var(--color-hairline)]",
				// 移动端紧凑 padding,桌面端留白
				"px-5 sm:px-8 lg:px-10 xl:px-14",
				"pt-5 sm:pt-6 lg:pt-8",
				"pb-6 sm:pb-8 lg:pb-10",
				"lg:min-h-screen",
			]}
			aria-label={lang === "zh" ? "文章信息栏" : "Post sidebar"}
		>
			{/* ---- Logo ---- */}
			<div class="flex items-center">
				<Logo size="md" />
			</div>

			<hr
				class="border-0 border-t border-dashed border-[color:var(--color-hairline)] mt-5 sm:mt-6 lg:mt-8"
				aria-hidden="true"
			/>

			{/* ---- 返回博客列表的快捷链接 ---- */}
			<a
				href={tp("/blog")}
				class:list={[
					"group",
					"mt-5 sm:mt-6 lg:mt-8",
					"inline-flex items-center gap-2",
					"font-[var(--font-mono)]",
					"text-[10.5px]",
					"leading-none",
					"tracking-[var(--tracking-wider)]",
					"uppercase",
					"text-[color:var(--color-ink-tertiary)]",
					"hover:text-[color:var(--color-ink-primary)]",
					"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
					"w-fit",
				]}
			>
				<svg
					aria-hidden="true"
					width="11"
					height="11"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
					class:list={[
						"shrink-0",
						"transition-transform duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						"group-hover:-translate-x-[2px]",
					]}
				>
					<path d="m12 19-7-7 7-7"></path>
					<path d="M19 12H5"></path>
				</svg>
				<span>{C.backToList}</span>
			</a>

			{/* ---- 文章标题(大字,左栏主视觉) ----
			 * 移动端字号缩小,避免在 320~375px 窄屏下撑满多行把右栏推下去
			 */}
			<h1
				class:list={[
					"mt-6 sm:mt-8 lg:mt-10",
					"font-medium",
					"text-[color:var(--color-ink-primary)]",
					"tracking-[-0.02em]",
					"leading-[1.2]",
					"text-[22px] sm:text-[28px] md:text-[30px] lg:text-[32px] xl:text-[34px]",
				]}
			>
				{post.title}
			</h1>

			{/* ---- 摘要 ---- */}
			{post.excerpt && (
				<p
					class:list={[
						"mt-3 sm:mt-4",
						"text-[color:var(--color-ink-secondary)]",
						"text-[13.5px] sm:text-[14px] lg:text-[14.5px]",
						"leading-[1.65]",
						"max-w-[40ch]",
					]}
				>
					{post.excerpt}
				</p>
			)}

			{/* ---- 作者迷你卡片 ---- */}
			{post.authorName && (
				<a
					href={post.authorGithub ?? "#"}
					target={post.authorGithub ? "_blank" : undefined}
					rel={post.authorGithub ? "noopener noreferrer" : undefined}
					aria-label={C.viewAuthor}
					class:list={[
						"mt-5 sm:mt-7 lg:mt-8",
						"group",
						"flex items-center gap-3",
						"p-3",
						"border border-dashed border-[color:var(--color-hairline)]",
						"rounded-[var(--radius-sm)]",
						"bg-[color:var(--color-paper-muted)]/30",
						"hover:bg-[color:var(--color-paper-muted)]/60",
						"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						"w-fit",
						"max-w-full",
					]}
				>
					{post.authorAvatar ? (
						<img
							src={post.authorAvatar}
							alt={post.authorName}
							loading="lazy"
							decoding="async"
							class:list={[
								"shrink-0",
								"h-8 w-8",
								"rounded-full",
								"border border-[color:var(--color-hairline)]",
								"bg-[color:var(--color-paper-subtle)]",
							]}
						/>
					) : (
						<span
							aria-hidden="true"
							class:list={[
								"shrink-0",
								"inline-flex items-center justify-center",
								"h-8 w-8 rounded-full",
								"bg-[color:var(--color-ink-primary)]",
								"text-[color:var(--color-paper)]",
								"font-[var(--font-mono)]",
								"text-[12px] font-semibold",
								"uppercase tabular-nums",
							]}
						>
							{post.authorName.slice(0, 2)}
						</span>
					)}

					<div class="flex flex-col min-w-0">
						<span
							class:list={[
								"mono-label",
								"text-[9.5px] leading-none",
								"text-[color:var(--color-ink-tertiary)]",
								"mb-1",
							]}
						>
							{C.author}
						</span>
						<span
							class:list={[
								"text-[13px] leading-none",
								"text-[color:var(--color-ink-primary)]",
								"font-medium",
								"truncate",
								"group-hover:underline",
								"decoration-[color:var(--color-hairline-strong)]",
								"underline-offset-2",
							]}
						>
							{post.authorName}
						</span>
					</div>
				</a>
			)}

			{/* ---- 将后面的 meta 推到底部 ---- */}
			<div class="flex-1" aria-hidden="true"></div>

			{/* ---- Meta 元信息(底部) ----
			 * 移动端折叠到 <details>,默认收起,避免把右栏正文推到很远下方
			 * 桌面端(lg+)常驻展示,作为文章信息卡片
			 */}

			{/* 移动/中屏:折叠版 */}
			<details
				class:list={[
					"post-meta-collapsible",
					"lg:hidden",
					"mt-6 pt-4",
					"border-t border-dashed border-[color:var(--color-hairline)]",
				]}
			>
				<summary
					class:list={[
						"flex items-center justify-between gap-2",
						"cursor-pointer select-none list-none py-1",
					]}
				>
					<span class="mono-label text-[11px] text-[color:var(--color-ink-tertiary)]">
						{C.tags && post.tags.length > 0 ? `META · ${C.tags}` : "META"}
					</span>
					<span
						aria-hidden="true"
						class:list={[
							"post-meta-chevron",
							"inline-flex items-center justify-center h-5 w-5",
							"text-[color:var(--color-ink-muted)]",
							"transition-transform duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						]}
					>
						<svg
							width="12"
							height="12"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<path d="m6 9 6 6 6-6" />
						</svg>
					</span>
				</summary>

				<dl class="flex flex-col mt-2">
					<MetaRow label={C.published} value={formatDate(post.date, lang)} />
					{post.updatedDate && post.updatedDate !== post.date && (
						<MetaRow
							label={C.updated}
							value={formatDate(post.updatedDate, lang)}
						/>
					)}
					{post.categoryName && post.categorySlug && (
						<MetaRow label={C.category}>
							<Fragment slot="value">
								<span class="uppercase">{post.categoryName}</span>
							</Fragment>
						</MetaRow>
					)}
					<MetaRow label={C.readingTime}>
						<Fragment slot="value">
							<span class="tabular-nums">{readingTimeMin}</span>
							<span class="ml-1 uppercase">{C.minutes}</span>
						</Fragment>
					</MetaRow>
					{wordCount > 0 && (
						<MetaRow label={lang === "zh" ? "字数" : "Words"}>
							<Fragment slot="value">
								<span class="tabular-nums">{wordCount.toLocaleString()}</span>
								<span class="ml-1 uppercase">{C.words}</span>
							</Fragment>
						</MetaRow>
					)}
				</dl>

				{/* ---- 标签云(折叠内) ---- */}
				{post.tags.length > 0 && (
					<div class="mt-5">
						<span
							class:list={[
								"mono-label",
								"text-[10px] leading-none",
								"text-[color:var(--color-ink-tertiary)]",
								"tracking-[var(--tracking-wider)]",
								"uppercase",
								"block mb-2.5",
							]}
						>
							{C.tags}
						</span>
						<ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
							{post.tags.map((tag) => (
								<li class="inline-flex">
									<span
										class:list={[
											"inline-flex items-center",
											"px-2 py-[3px]",
											"font-[var(--font-mono)]",
											"text-[10px]",
											"leading-none",
											"tracking-[var(--tracking-wide)]",
											"text-[color:var(--color-ink-secondary)]",
											"bg-[color:var(--color-paper-muted)]/60",
											"border border-[color:var(--color-hairline)]",
											"rounded-[var(--radius-sm)]",
										]}
									>
										<span
											aria-hidden="true"
											class="text-[color:var(--color-ink-muted)] mr-[2px]"
										>
											#
										</span>
										{tag.name}
									</span>
								</li>
							))}
						</ul>
					</div>
				)}
			</details>

			{/* 桌面端:常驻展示 */}
			<div
				class:list={[
					"hidden lg:block",
					"mt-10 lg:mt-12",
					"pt-4",
					"border-t border-dashed border-[color:var(--color-hairline)]",
				]}
			>
				<dl class="flex flex-col">
					<MetaRow label={C.published} value={formatDate(post.date, lang)} />
					{post.updatedDate && post.updatedDate !== post.date && (
						<MetaRow
							label={C.updated}
							value={formatDate(post.updatedDate, lang)}
						/>
					)}
					{post.categoryName && post.categorySlug && (
						<MetaRow label={C.category}>
							<Fragment slot="value">
								<span class="uppercase">{post.categoryName}</span>
							</Fragment>
						</MetaRow>
					)}
					<MetaRow label={C.readingTime}>
						<Fragment slot="value">
							<span class="tabular-nums">{readingTimeMin}</span>
							<span class="ml-1 uppercase">{C.minutes}</span>
						</Fragment>
					</MetaRow>
					{wordCount > 0 && (
						<MetaRow label={lang === "zh" ? "字数" : "Words"}>
							<Fragment slot="value">
								<span class="tabular-nums">{wordCount.toLocaleString()}</span>
								<span class="ml-1 uppercase">{C.words}</span>
							</Fragment>
						</MetaRow>
					)}
				</dl>

				{/* ---- 标签云(桌面) ---- */}
				{post.tags.length > 0 && (
					<div class="mt-5">
						<span
							class:list={[
								"mono-label",
								"text-[10px] leading-none",
								"text-[color:var(--color-ink-tertiary)]",
								"tracking-[var(--tracking-wider)]",
								"uppercase",
								"block mb-2.5",
							]}
						>
							{C.tags}
						</span>
						<ul class="flex flex-wrap gap-1.5 list-none m-0 p-0">
							{post.tags.map((tag) => (
								<li class="inline-flex">
									<span
										class:list={[
											"inline-flex items-center",
											"px-2 py-[3px]",
											"font-[var(--font-mono)]",
											"text-[10px]",
											"leading-none",
											"tracking-[var(--tracking-wide)]",
											"text-[color:var(--color-ink-secondary)]",
											"bg-[color:var(--color-paper-muted)]/60",
											"border border-[color:var(--color-hairline)]",
											"rounded-[var(--radius-sm)]",
										]}
									>
										<span
											aria-hidden="true"
											class="text-[color:var(--color-ink-muted)] mr-[2px]"
										>
											#
										</span>
										{tag.name}
									</span>
								</li>
							))}
						</ul>
					</div>
				)}
			</div>
		</aside>
	</Fragment>

	{/* ==========================================================================
	 *                              右栏主内容
	 * ========================================================================== */}

	{/* ---- 面包屑 + slug 标签 ---- */}
	<div
		class:list={[
			"flex items-center gap-2",
			"font-[var(--font-mono)]",
			"text-[10.5px]",
			"leading-none",
			"tracking-[var(--tracking-wider)]",
			"uppercase",
			"text-[color:var(--color-ink-tertiary)]",
			"mb-2",
		]}
	>
		<a
			href={tp("/blog")}
			class:list={[
				"hover:text-[color:var(--color-ink-primary)]",
				"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
			]}
		>
			{C.blogBreadcrumb}
		</a>
		<span aria-hidden="true" class="text-[color:var(--color-ink-muted)]">
			/
		</span>
		<span
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"truncate max-w-[32ch]",
			]}
		>
			{post.slug}
		</span>
	</div>

	{/* ---- 分区头 ---- */}
	<SectionHeader
		eyebrow={post.categoryName ?? C.blogBreadcrumb}
		count={formatDateCompact(post.date)}
	/>

	{/* ---- 正文 + TOC 的两列布局 ----
	 * 布局策略(响应式全宽,正文 + TOC 共同吃满右栏):
	 *   - 右栏容器走 maxContentWidth="none",跟随屏幕宽度无上限
	 *   - 正文 prose 用 flex-1 吃掉 TOC 以外的全部宽度,不再用 ch 锁定上限
	 *     用户偏好:高分辨率大屏上内容区域宽度接近 100%,宁可单行略长也不
	 *     留大片空白。可读性由字号 / 行高 / 段距共同保证
	 *   - TOC 固定 220 / 240 / 260px,贴在右栏右侧
	 *   - 移动端两栏塌陷为单列,TOC 置于正文上方
	 */}
	<div
		class:list={[
			"mt-6 lg:mt-8 mb-12",
			"flex flex-col lg:flex-row",
			"gap-8 lg:gap-12 xl:gap-16",
			"items-start",
		]}
	>
		{/* Article */}
		<article
			class:list={[
				"prose",
				"blog-post-article",
				"min-w-0",
				"w-full",
				"lg:flex-1",
				// 全宽填充,不再施加 ch 级别的 max-width 上限
				"max-w-none",
			]}
			set:html={renderedHtml}
		/>

		{/* TOC(桌面端右侧贴边,平板/移动不占位) */}
		{headings.length > 0 && (
			<div
				class:list={[
					"w-full",
					"lg:w-[220px] xl:w-[240px] 2xl:w-[260px] lg:shrink-0",
					// 平板 / 移动端让 TOC 显示在正文上方以免被忽视
					"order-first lg:order-last",
				]}
			>
				<TableOfContents headings={headings} defaultOpen={true} />
			</div>
		)}
	</div>

	{/* ---- 图片 Lightbox 容器(点击正文图片时放大查看) ---- */}
	<div
		id="image-lightbox"
		class="image-lightbox"
		role="dialog"
		aria-modal="true"
		aria-label={lang === "zh" ? "图片查看器" : "Image viewer"}
		aria-hidden="true"
		hidden
	>
		<button
			type="button"
			class="image-lightbox__close"
			aria-label={lang === "zh" ? "关闭" : "Close"}
		>
			<svg
				aria-hidden="true"
				width="18"
				height="18"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
		</button>
		<figure class="image-lightbox__figure">
			<img class="image-lightbox__img" alt="" />
			<figcaption class="image-lightbox__caption"></figcaption>
		</figure>
	</div>

	{/* ---- 分割线 ---- */}
	<hr
		aria-hidden="true"
		class="border-0 border-t border-dashed border-[color:var(--color-hairline)] my-8"
	/>

	{/* ---- 上一篇 / 下一篇 ---- */}
	{(prevVM || nextVM) && (
		<nav
			aria-label={lang === "zh" ? "文章导航" : "Post navigation"}
			class:list={[
				"mt-2 mb-16",
				"grid grid-cols-1 sm:grid-cols-2",
				"gap-0",
				"border border-dashed border-[color:var(--color-hairline)]",
				"divide-x divide-dashed divide-[color:var(--color-hairline)]",
			]}
		>
			{/* 上一篇 */}
			{prevVM ? (
				<a
					href={tp(`/blog/${prevVM.slug}`)}
					class:list={[
						"group",
						"flex flex-col gap-2",
						"px-5 py-5 lg:px-6 lg:py-6",
						"hover:bg-[color:var(--color-paper-muted)]/60",
						"transition-colors duration-[var(--duration-base)] ease-[var(--ease-standard)]",
						"sm:border-r-0",
					]}
				>
					<span
						class:list={[
							"inline-flex items-center gap-1.5",
							"mono-label",
							"text-[10px]",
							"text-[color:var(--color-ink-tertiary)]",
							"group-hover:text-[color:var(--color-ink-primary)]",
							"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						]}
					>
						<svg
							aria-hidden="true"
							width="10"
							height="10"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							class:list={[
								"shrink-0",
								"transition-transform duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
								"group-hover:-translate-x-[2px]",
							]}
						>
							<path d="m12 19-7-7 7-7"></path>
							<path d="M19 12H5"></path>
						</svg>
						{C.prev}
					</span>
					<span
						class:list={[
							"text-[14px] lg:text-[14.5px]",
							"leading-[1.45]",
							"text-[color:var(--color-ink-primary)]",
							"font-medium",
							"line-clamp-2",
						]}
					>
						{prevVM.title}
					</span>
				</a>
			) : (
				<div aria-hidden="true" class="hidden sm:block"></div>
			)}

			{/* 下一篇 */}
			{nextVM ? (
				<a
					href={tp(`/blog/${nextVM.slug}`)}
					class:list={[
						"group",
						"flex flex-col gap-2 items-end text-right",
						"px-5 py-5 lg:px-6 lg:py-6",
						"hover:bg-[color:var(--color-paper-muted)]/60",
						"transition-colors duration-[var(--duration-base)] ease-[var(--ease-standard)]",
					]}
				>
					<span
						class:list={[
							"inline-flex items-center gap-1.5",
							"mono-label",
							"text-[10px]",
							"text-[color:var(--color-ink-tertiary)]",
							"group-hover:text-[color:var(--color-ink-primary)]",
							"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						]}
					>
						{C.next}
						<svg
							aria-hidden="true"
							width="10"
							height="10"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							class:list={[
								"shrink-0",
								"transition-transform duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
								"group-hover:translate-x-[2px]",
							]}
						>
							<path d="M5 12h14"></path>
							<path d="m12 5 7 7-7 7"></path>
						</svg>
					</span>
					<span
						class:list={[
							"text-[14px] lg:text-[14.5px]",
							"leading-[1.45]",
							"text-[color:var(--color-ink-primary)]",
							"font-medium",
							"line-clamp-2",
						]}
					>
						{nextVM.title}
					</span>
				</a>
			) : (
				<div aria-hidden="true" class="hidden sm:block"></div>
			)}
		</nav>
	)}
</AppShell>

<style>
	/* ----------------------------------------------------------------------------
	 * line-clamp 兜底(相邻文章标题)
	 * -------------------------------------------------------------------------- */

	.line-clamp-2 {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ----------------------------------------------------------------------------
	 * 移动端 meta 折叠区:自定义 summary 箭头
	 * -------------------------------------------------------------------------- */
	.post-meta-collapsible > summary {
		list-style: none;
	}
	.post-meta-collapsible > summary::-webkit-details-marker {
		display: none;
	}
	.post-meta-collapsible[open] .post-meta-chevron {
		transform: rotate(180deg);
	}

	/* ----------------------------------------------------------------------------
	 * 全宽覆盖:解除 prose.css 默认的 72ch 最大宽度上限
	 * --------------------------------------------------------------------------
	 * prose.css 里 `.prose { max-width: 72ch }` 是为通用长文阅读服务的,
	 * 博客详情页用户明确偏好全宽填充,这里用 .blog-post-article 作用域把它解除,
	 * 只影响本组件,不污染项目内其他使用 .prose 的地方(如 about 页)。
	 * -------------------------------------------------------------------------- */
	.blog-post-article.prose {
		max-width: none;
	}

	/* ----------------------------------------------------------------------------
	 * 正文图片可点击放大的视觉提示(hover 时微微浮起 + cursor: zoom-in)
	 * -------------------------------------------------------------------------- */
	.blog-post-article :global(img) {
		cursor: zoom-in;
		transition:
			transform var(--duration-base) var(--ease-standard),
			box-shadow var(--duration-base) var(--ease-standard);
	}
	.blog-post-article :global(img:hover) {
		transform: translateY(-1px);
		box-shadow: 0 6px 24px -12px rgba(0, 0, 0, 0.25);
	}

	/* ----------------------------------------------------------------------------
	 * 图片 Lightbox —— 点击正文图片时放大查看
	 * --------------------------------------------------------------------------
	 * 纯 CSS + 轻量 JS 实现,不引入任何三方库。
	 * - 默认 hidden(display:none),由 JS 切换 data-open="true" 显示
	 * - 遮罩层占满视口,暗色半透明背景,图片居中自适应
	 * - 点击遮罩 / 关闭按钮 / Esc 键均可关闭
	 * -------------------------------------------------------------------------- */
	.image-lightbox {
		position: fixed;
		inset: 0;
		z-index: 100;
		display: none;
		align-items: center;
		justify-content: center;
		padding: 2rem 1.25rem;
		background-color: rgba(20, 20, 20, 0.88);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		opacity: 0;
		transition: opacity var(--duration-base) var(--ease-standard);
	}

	.image-lightbox[data-open="true"] {
		display: flex;
		opacity: 1;
	}

	.image-lightbox__close {
		position: absolute;
		top: 1rem;
		right: 1rem;
		width: 40px;
		height: 40px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: var(--radius-sm);
		border: 1px dashed rgba(255, 255, 255, 0.35);
		background-color: rgba(255, 255, 255, 0.05);
		color: rgba(255, 255, 255, 0.92);
		cursor: pointer;
		transition:
			background-color var(--duration-fast) var(--ease-standard),
			border-color var(--duration-fast) var(--ease-standard);
	}

	.image-lightbox__close:hover {
		background-color: rgba(255, 255, 255, 0.12);
		border-color: rgba(255, 255, 255, 0.6);
	}

	.image-lightbox__close:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.8);
		outline-offset: 2px;
	}

	.image-lightbox__figure {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.75rem;
		max-width: min(96vw, 1400px);
		max-height: 90vh;
	}

	.image-lightbox__img {
		display: block;
		max-width: 100%;
		max-height: 82vh;
		width: auto;
		height: auto;
		object-fit: contain;
		border-radius: var(--radius-sm);
		background-color: rgba(0, 0, 0, 0.25);
		box-shadow: 0 24px 64px -12px rgba(0, 0, 0, 0.6);
		cursor: zoom-out;
	}

	.image-lightbox__caption {
		font-family: var(--font-mono);
		font-size: 12px;
		letter-spacing: var(--tracking-wide);
		color: rgba(255, 255, 255, 0.72);
		text-align: center;
		max-width: 72ch;
	}

	.image-lightbox__caption:empty {
		display: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.image-lightbox,
		.blog-post-article :global(img) {
			transition: none;
		}
	}
</style>

<script>
	/**
	 * ------------------------------------------------------------------------
	 * 博客详情页:图片 Lightbox 交互
	 * ------------------------------------------------------------------------
	 * 绑定对象:.blog-post-article 内所有 <img>
	 * 行为:
	 *   - 点击图片 → 打开 lightbox,填充 src/alt/title
	 *   - 点击遮罩 / 关闭按钮 / 图片本身 / Esc 键 → 关闭
	 *   - 打开时锁定 body 滚动
	 * 使用事件委托,一次绑定在文章容器上,适配 Astro view transitions
	 * ------------------------------------------------------------------------ */
	// 通过 data 属性标记已绑定,避免 ViewTransitions 场景下的重复绑定
	const LIGHTBOX_BOUND_ATTR = "data-lightbox-bound";
	const ESC_HANDLER_KEY = "__zerxLightboxEsc";

	function setupImageLightbox() {
		const article = document.querySelector<HTMLElement>(".blog-post-article");
		const lightbox = document.getElementById("image-lightbox");
		if (!article || !lightbox) return;

		// 幂等:已绑定过就直接返回,防止 astro:page-load 多次注册导致监听重复
		if (article.getAttribute(LIGHTBOX_BOUND_ATTR) === "true") return;
		article.setAttribute(LIGHTBOX_BOUND_ATTR, "true");

		const imgEl = lightbox.querySelector<HTMLImageElement>(
			".image-lightbox__img",
		);
		const captionEl = lightbox.querySelector<HTMLElement>(
			".image-lightbox__caption",
		);
		const closeBtn = lightbox.querySelector<HTMLButtonElement>(
			".image-lightbox__close",
		);
		if (!imgEl || !captionEl || !closeBtn) return;

		let lastFocused: HTMLElement | null = null;

		function open(src: string, alt: string, caption: string) {
			if (!imgEl || !captionEl || !lightbox) return;
			imgEl.src = src;
			imgEl.alt = alt;
			captionEl.textContent = caption;
			lightbox.hidden = false;
			// 下一帧再加 data-open,触发 CSS 过渡
			requestAnimationFrame(() => {
				lightbox.setAttribute("data-open", "true");
				lightbox.setAttribute("aria-hidden", "false");
			});
			document.body.style.overflow = "hidden";
			lastFocused = document.activeElement as HTMLElement | null;
			closeBtn?.focus();
		}

		function close() {
			if (!lightbox) return;
			lightbox.removeAttribute("data-open");
			lightbox.setAttribute("aria-hidden", "true");
			document.body.style.overflow = "";
			// 等过渡结束再 hidden
			window.setTimeout(() => {
				if (!lightbox.hasAttribute("data-open")) {
					lightbox.hidden = true;
					if (imgEl) imgEl.src = "";
				}
			}, 220);
			if (lastFocused && typeof lastFocused.focus === "function") {
				lastFocused.focus();
			}
		}

		article.addEventListener("click", (e) => {
			const target = e.target as HTMLElement | null;
			if (!target) return;
			const img = target.closest("img");
			if (!img || !article.contains(img)) return;
			// 忽略被 <a> 包裹的图片(作者另行指定了跳转意图)
			if (img.closest("a")) return;
			e.preventDefault();
			const src = img.currentSrc || img.src;
			const alt = img.getAttribute("alt") ?? "";
			const title = img.getAttribute("title") ?? "";
			open(src, alt, title || alt);
		});

		closeBtn.addEventListener("click", close);
		lightbox.addEventListener("click", (e) => {
			if (e.target === lightbox || e.target === imgEl) close();
		});

		// Esc 关闭:全局只保留一份,重复初始化时先解绑旧的
		const w = window as unknown as Record<string, unknown>;
		const prevEsc = w[ESC_HANDLER_KEY] as
			| ((e: KeyboardEvent) => void)
			| undefined;
		if (prevEsc) document.removeEventListener("keydown", prevEsc);
		const escHandler = (e: KeyboardEvent) => {
			if (e.key === "Escape" && lightbox.getAttribute("data-open") === "true") {
				close();
			}
		};
		w[ESC_HANDLER_KEY] = escHandler;
		document.addEventListener("keydown", escHandler);

		// 标记图片可点击(供辅助技术识别)
		article.querySelectorAll("img").forEach((img) => {
			if (img.closest("a")) return;
			img.setAttribute("role", "button");
			img.setAttribute("tabindex", "0");
			img.addEventListener("keydown", (e) => {
				const ke = e as KeyboardEvent;
				if (ke.key === "Enter" || ke.key === " ") {
					ke.preventDefault();
					const src = img.currentSrc || img.src;
					const alt = img.getAttribute("alt") ?? "";
					const title = img.getAttribute("title") ?? "";
					open(src, alt, title || alt);
				}
			});
		});
	}

	// 首次加载 + Astro 客户端导航后(若启用 ViewTransitions)重新初始化
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", setupImageLightbox);
	} else {
		setupImageLightbox();
	}
	document.addEventListener("astro:page-load", setupImageLightbox);
</script>
