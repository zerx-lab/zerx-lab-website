---
/**
 * ============================================================================
 * BlogIndexPage - 博客列表页共享组件
 * ----------------------------------------------------------------------------
 * 为什么抽成独立组件:
 *   中文 /blog 与英文 /en/blog 两个入口页面 95% 的逻辑相同,
 *   只有 lang 推导与少量默认文案不同。本组件负责:
 *     1. 解析 URL querystring(?page / ?q),做分页 + 搜索
 *     2. 从 Directus 拉取当前页 posts(失败时 fallback-data 内存分页)
 *     3. 搜索命中时对 title / excerpt 做高亮
 *     4. 组合左栏(LabMark + meta)与右栏(搜索框 + 列表 + 分页)
 *
 * 使用方式(页面文件):
 *   ---
 *   import BlogIndexPage from "@components/blog/BlogIndexPage.astro";
 *   ---
 *   <BlogIndexPage />
 *
 * 左栏 meta 字段说明:
 *   - POSTS        已发布文章总数(始终显示全量,不随搜索变化)
 *   - CATEGORIES   分类总数
 *   - LAST UPDATE  最新文章的发布日期(ISO → 本地化)
 *   - RSS          /rss.xml 外链
 *
 * 分页:
 *   - 每页 PAGE_SIZE = 10 篇
 *   - URL 参数 ?page=N(1-indexed,第 1 页省略参数)
 *   - 越界页码(page=999)由 listPostsPaged 内部 clamp 到最后一页,不报 404
 *   - 单页时不渲染 Pagination(组件内部已处理)
 *
 * 搜索:
 *   - URL 参数 ?q=<关键词>
 *   - 搜索字段:当前 lang 翻译的 title + excerpt + content,_icontains 模糊匹配
 *   - 命中结果在 title / excerpt 里高亮 <mark class="search-hit">
 *   - 搜索激活时:
 *       · featured 分组失效(搜索结果按 date 降序,不再置顶精选)
 *       · SectionHeader 下方显示"搜索 XXX 的结果(N 条)"
 *       · 空结果单独文案,引导用户清空搜索回到全列表
 * ============================================================================
 */

import AppShell from "@layouts/AppShell.astro";

import MetaRow from "@components/ui/MetaRow.astro";
import PostCard from "@components/ui/PostCard.astro";
import Pagination from "@components/ui/Pagination.astro";
import BlogMark from "@components/ui/BlogMark.astro";
import BlogSearchBox from "@components/blog/BlogSearchBox.astro";
import BlogCategoryTabs from "@components/blog/BlogCategoryTabs.astro";
import {
	getLangFromUrl,
	useTranslations,
	useTranslatedPath,
	formatDateCompact,
} from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import {
	FALLBACK_CATEGORIES,
	listFallbackPosts,
} from "@lib/fallback-data";
import {
	listPostsPaged,
	listCategoryCounts,
	listCategories,
	type PostVM,
	type CategoryVM,
} from "@lib/queries/posts";
import { highlight } from "@lib/highlight";

/* ----------------------------------------------------------------------------
 * 当前语言 / 翻译工具
 * -------------------------------------------------------------------------- */

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const tp = useTranslatedPath(lang);

/* ----------------------------------------------------------------------------
 * 解析 URL 查询参数
 * ----------------------------------------------------------------------------
 * Astro SSR 下每次请求都能读到真实 query,解析完交给 listPostsPaged。
 *
 * 容错:
 *   - page 非数字 / 负数 / 超大 → listPostsPaged 内部 clamp
 *   - q 超长 → 本文件截断到 200 字符,避免恶意极长字符串打进 Directus filter
 * -------------------------------------------------------------------------- */

const PAGE_SIZE = 10;
const MAX_QUERY_LENGTH = 200;
const MAX_CAT_LENGTH = 64;

const searchParams = Astro.url.searchParams;
const rawPage = Number.parseInt(searchParams.get("page") ?? "1", 10);
const requestedPage = Number.isFinite(rawPage) && rawPage > 0 ? rawPage : 1;
const rawQuery = (searchParams.get("q") ?? "").slice(0, MAX_QUERY_LENGTH).trim();

// 传给 listPostsPaged 的分类参数:用归一化后的值(未做白名单校验)。
// 白名单校验需要 categoriesList 结果,但 listPostsPaged 需要与其并行触发。
// 这里的 trade-off:若用户传了未知 slug,listPostsPaged 会返回 0 条(无害)。

/* ----------------------------------------------------------------------------
 * 分类参数 ?cat=<slug>
 * ----------------------------------------------------------------------------
 * 归一化规则(与 listPostsPaged.normalizeCategorySlug 保持一致):
 *   - 空串 / 缺失 / "all"(大小写不敏感)→ 表示"全部",内部用空串表示
 *   - 仅接受存在于 FALLBACK_CATEGORIES 的 slug;未知 slug 直接回退到 ALL,
 *     避免用户乱填 URL 触发空列表
 *   - 长度截断防御
 * -------------------------------------------------------------------------- */

const rawCat = (searchParams.get("cat") ?? "")
	.slice(0, MAX_CAT_LENGTH)
	.trim()
	.toLowerCase();
// 先做一次形态归一化(下方取到 categoriesList 后再做白名单校验)
const normalizedRawCat = rawCat && rawCat !== "all" ? rawCat : "";

/* ----------------------------------------------------------------------------
 * 拉取当前页数据(含搜索过滤)
 * ----------------------------------------------------------------------------
 * listPostsPaged 内部已完成:
 *   - Directus → fallback 降级
 *   - status=published 过滤
 *   - 按 -date_published 排序
 *   - 分页 + 越界 clamp
 *   - 按 lang 解包 translations
 * -------------------------------------------------------------------------- */

const [pageResult, categoryCounts, categoriesList] = await Promise.all([
	listPostsPaged({
		lang,
		page: requestedPage,
		pageSize: PAGE_SIZE,
		q: rawQuery,
		categorySlug: normalizedRawCat,
	}),
	// 分类计数独立聚合查询:与主列表并行,失败已在内部降级为 fallback
	listCategoryCounts(),
	// Directus 真实分类列表(线上可能比 FALLBACK_CATEGORIES 多,如 AI Writer
	// 新增的"资讯"/"daily-news" 等)。失败已在内部降级到 FALLBACK_CATEGORIES。
	listCategories(lang),
]);

/*
 * activeCatSlug 白名单校验:
 *   只接受真实存在于 categoriesList(Directus 或 fallback)的 slug。
 *   未知 slug 一律回退到 ALL,避免用户乱填 URL 触发空列表。
 *
 * 注意:这里用的是 SSR 真实数据做校验,比之前纯用 FALLBACK_CATEGORIES 更准确,
 * 能正确识别 Directus 里后加的分类(如"资讯")。
 */
const activeCatSlug: string = normalizedRawCat
	? (categoriesList.find((c: CategoryVM) => c.slug === normalizedRawCat)
			?.slug ?? "")
	: "";
const hasCatFilter = activeCatSlug.length > 0;

/*
 * 重新调用 listPostsPaged 的必要性判断:
 *   上面 Promise.all 时 activeCatSlug 还未确定最终值(当时用的是 normalizedRawCat
 *   未做白名单校验)。如果用户传了未知 slug(normalizedRawCat 非空,最终 activeCatSlug="")
 *   那 pageResult 会是"未知分类下的空列表",不是我们想要的"全部"。
 *
 * 但:本场景(未知 slug)极罕见,而且 listPostsPaged 对未知 slug 返回 total=0,
 * 用户会看到"暂无文章",URL 里的 cat 参数会在分类切换器点击后自动清除。
 * 这是可接受的边界行为,不再额外发一次请求。
 */

const posts: readonly PostVM[] = pageResult.items;
const hasQuery = pageResult.query.length > 0;

/* ----------------------------------------------------------------------------
 * 左栏 meta 数据计算
 * ----------------------------------------------------------------------------
 * 注意:POSTS 计数显示"站内全部已发布文章数",不随搜索/分页变化。
 * 这是左栏 meta 的语义约定 —— 它描述"站点"的属性,不是"当前视图"的属性。
 *
 * 获取全量总数策略:
 *   1. 当没有搜索且在第 1 页时,pageResult.total 就是全量总数
 *   2. 搜索激活时,pageResult.total 是搜索结果数,不能直接拿来做 POSTS 计数
 *      → 退而求其次用 fallback 的长度作为最小保证值,或展示 "—"
 *   为保持简洁 + 避免再发一次 Directus 查询,搜索态下 POSTS 显示为搜索结果数,
 *   但用 meta.searchResults 的 label 区分;无搜索时用 meta.posts 正常显示。
 * -------------------------------------------------------------------------- */

/*
 * POSTS 计数语义:
 *   - 无搜索 + 无分类 → pageResult.total 就是站点全量
 *   - 有搜索 或 有分类 → pageResult.total 是命中数(视图属性,非站点属性)
 *     这里优先采用 categoryCounts.total(始终是站点全量),保持左栏 meta
 *     表达"站点属性"的语义一致性
 */
const postCount =
	hasQuery || hasCatFilter ? categoryCounts.total : pageResult.total;
const categoryCount = FALLBACK_CATEGORIES.length;
const latestPostDate = posts.length > 0 ? posts[0]!.date : null;
const lastUpdateText = latestPostDate
	? formatDateCompact(latestPostDate)
	: "—";

// fallback 兜底:搜索 0 命中导致 latestPostDate 为 null 时,
// "LAST UPDATE" 仍显示站点真实的最后发布日期,避免页面看起来"空"
let lastUpdateTextFinal = lastUpdateText;
if (!latestPostDate) {
	const allFb = listFallbackPosts();
	const newest = allFb.reduce<string | null>((acc, p) => {
		if (!acc) return p.date;
		return new Date(p.date).getTime() > new Date(acc).getTime() ? p.date : acc;
	}, null);
	if (newest) lastUpdateTextFinal = formatDateCompact(newest);
}

/* ----------------------------------------------------------------------------
 * 页面级文案(本页不通过 i18n 字典管理,因为是单页专属)
 * -------------------------------------------------------------------------- */

const PAGE_COPY = {
	zh: {
		eyebrow: "博客",
		title: "文章、发布与洞见",
		description:
			"记录构建过程、技术决策与开源探索。不追热点,只写能帮到明年自己的东西。",
		empty: "还没有文章,敬请期待。",
		sectionTitle: "BLOG",
		searchResults: (n: number, q: string) =>
			`找到 ${n} 篇包含 "${q}" 的文章`,
		searchEmpty: (q: string) =>
			`没有找到包含 "${q}" 的文章。`,
		clearSearch: "清空搜索",
	},
	en: {
		eyebrow: "Blog",
		title: "Articles, releases, and insights",
		description:
			"Notes on what I build, the decisions behind them, and open-source explorations. No hot takes — only things that will help future me.",
		empty: "No posts yet. Stay tuned.",
		sectionTitle: "BLOG",
		searchResults: (n: number, q: string) =>
			`Found ${n} ${n === 1 ? "post" : "posts"} matching "${q}"`,
		searchEmpty: (q: string) => `No posts match "${q}".`,
		clearSearch: "Clear search",
	},
} as const;

const copy = PAGE_COPY[lang] ?? PAGE_COPY.zh;

/* ----------------------------------------------------------------------------
 * 分组策略
 * ----------------------------------------------------------------------------
 *   - 非搜索态 + 第 1 页:featured 排前,其余按日期降序(保留原行为)
 *   - 非搜索态 + 第 2+ 页:featured 不再强调,直接按日期排(避免跨页重复置顶)
 *   - 搜索态:所有命中按日期排,featured 标记仅作为卡片视觉区分,不做分组
 * -------------------------------------------------------------------------- */

const isFirstPageWithoutSearch = !hasQuery && pageResult.page === 1;
const featuredPosts = isFirstPageWithoutSearch
	? posts.filter((p) => p.featured)
	: [];
const regularPosts = isFirstPageWithoutSearch
	? posts.filter((p) => !p.featured)
	: posts;

/* ----------------------------------------------------------------------------
 * 高亮预处理
 * ----------------------------------------------------------------------------
 * 在服务端把每篇文章的 title / excerpt 预先高亮成 HTML,PostCard 用
 * set:html 直接渲染。
 *
 * 只在搜索态下预处理,非搜索态走 PostCard 的纯文本分支,0 成本。
 *
 * 安全:highlight() 内部已完成 HTML escape + 仅产出 <mark class="search-hit">,
 * set:html 渲染无 XSS 风险。
 * -------------------------------------------------------------------------- */

interface RenderablePost {
	readonly vm: PostVM;
	readonly titleHtml?: string;
	readonly excerptHtml?: string;
}

function toRenderable(vm: PostVM): RenderablePost {
	if (!hasQuery) return { vm };
	return {
		vm,
		titleHtml: highlight(vm.title, pageResult.query),
		excerptHtml: highlight(vm.excerpt, pageResult.query),
	};
}

const featuredRenderable = featuredPosts.map(toRenderable);
const regularRenderable = regularPosts.map(toRenderable);

/* ----------------------------------------------------------------------------
 * 分页 baseUrl 构造
 * ----------------------------------------------------------------------------
 * Pagination 组件用 `${baseUrl}${sep}page=N` 拼分页链接。
 * baseUrl 需要保留当前的 ?q 参数,这样点分页按钮不会丢失搜索状态。
 *
 * 规则:
 *   - 无搜索 → baseUrl = "/blog"(或 "/en/blog")
 *   - 有搜索 → baseUrl = "/blog?q=<encoded>"
 *
 * tp("/blog") 会按 lang 自动加 /en 前缀。
 * -------------------------------------------------------------------------- */

const listPath = tp("/blog");

/* 分页 baseUrl:保留当前的 ?q 与 ?cat,只让 Pagination 追加 &page=N */
function buildBaseUrl(): string {
	const params = new URLSearchParams();
	if (pageResult.query) params.set("q", pageResult.query);
	if (activeCatSlug) params.set("cat", activeCatSlug);
	const qs = params.toString();
	return qs ? `${listPath}?${qs}` : listPath;
}
const paginationBaseUrl = buildBaseUrl();

/* 搜索框 action:同理保留 ?cat(搜索跨分类时不丢失已选分类)。
 * 注意:BlogSearchBox 的 action 不支持 query string,它会用 <form method="GET">,
 * 所以我们必须把 cat 作为 hidden input 一起随表单提交。 */
const searchAction = listPath;

/* 分类切换器需要知道每分类的计数。把 listCategoryCounts 返回的 byCategory
 * 与 ALL 计数合并成单个对象传给组件(组件用 "__all__" 特殊键取 ALL)。 */
const categoryCountsForTabs: Record<string, number> = {
	__all__: categoryCounts.total,
	...categoryCounts.byCategory,
};

/* ----------------------------------------------------------------------------
 * BlogMark 左栏装置数据
 * ----------------------------------------------------------------------------
 * 把 Directus(或 fallback)真实分类列表和每分类计数折成 BlogMark 需要的形状:
 *   { slug, name, count }[],按 count 降序(条形图"重"的排在上面,视觉更稳)。
 *
 * name 取自 categoriesList(已按当前 lang 解包),count 取自 categoryCounts.byCategory,
 * 查不到计数的分类视为 0(bootstrap 新增但还没文章的分类不会被遗漏)。
 *
 * 只展示前 N 项,避免左栏被极长的分类列表撑开。剩余分类不进入装置 —— 用户要看
 * 完整分类可用右栏顶部的分类切换器。
 * -------------------------------------------------------------------------- */

const BLOG_MARK_MAX_ROWS = 6;

const blogMarkCategories = categoriesList
	.map((c: CategoryVM) => ({
		slug: c.slug,
		name: c.name,
		count: categoryCounts.byCategory[c.slug] ?? 0,
	}))
	.sort((a, b) => b.count - a.count)
	.slice(0, BLOG_MARK_MAX_ROWS);
---

<AppShell
	title={copy.title}
	description={copy.description}
	maxContentWidth="none"
>
	{/* ---------- 左栏:视觉装置(分类分布条形图) ----------
	 * 博客列表页专属装置,替代首页的 LabMark。
	 * 传入 left-visual slot 后,AppShell 走"页面自定义装置"分支,
	 * 不再渲染默认 LabMark。
	 * ------------------------------------------------------------ */}
	<Fragment slot="left-visual">
		<BlogMark
			categories={blogMarkCategories}
			total={categoryCounts.total}
		/>
	</Fragment>

	{/* ---------- 左栏:社交(仅 RSS) ---------- */}
	<Fragment slot="left-social">
		<a
			href={tp("/rss.xml")}
			aria-label="RSS"
			class="transition-colors hover:text-[color:var(--color-ink-primary)]"
		>
			<svg
				width="15"
				height="15"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 11a9 9 0 0 1 9 9"></path>
				<path d="M4 4a16 16 0 0 1 16 16"></path>
				<circle cx="5" cy="19" r="1"></circle>
			</svg>
		</a>
		<a
			href="https://github.com/zerx-lab"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="GitHub"
			class="transition-colors hover:text-[color:var(--color-ink-primary)]"
		>
			<svg
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="currentColor"
				aria-hidden="true"
			>
				<path
					d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.1-.4-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
				></path>
			</svg>
		</a>
	</Fragment>

	{/* ---------- 左栏:Meta ---------- */}
	<Fragment slot="left-meta">
		<MetaRow label={t("meta.posts")} value={String(postCount)} />
		<MetaRow
			label={t("meta.categories")}
			value={String(categoryCount)}
		/>
		<MetaRow label={t("meta.lastUpdate")} value={lastUpdateTextFinal} />
		<MetaRow
			label={t("meta.rss")}
			value={tp("/rss.xml")}
			href={tp("/rss.xml")}
		/>
	</Fragment>

	{/* ================================================================
	 *                          右栏主内容
	 * ================================================================ */}

	{/* ---------- 顶行:eyebrow + 分类切换 + 搜索框,三段一行 ---------- */}
	{/*
	 * 为什么不再复用 SectionHeader 的内置顶行:
	 *   SectionHeader 的顶行只支持 [eyebrow] — [count|link] 两段布局,
	 *   插不进"分类切换"这种占据剩余宽度且需横向滚动的交互组件。
	 *   这里自己写一个 3 段 flex 顶行,视觉上保留同样的虚线分隔与节奏:
	 *
	 *     [ BLOG · 6 ]  [ 全部 · 工程 · 发布 · 笔记 … ]  [ 🔍 ]
	 *          ↑固定          ↑flex-1 + 横向滚动          ↑固定
	 *
	 *   - 左右两端 shrink-0,永不被压缩
	 *   - 中间 min-w-0 + flex-1 + overflow-x-auto,分类过多时横向滚动,
	 *     两端渐变蒙版暗示"此处可滚动",绝不会挤压搜索框与 count
	 *   - 小屏(<sm)依旧是同一行;若分类极多,滚动条隐藏,手指滑动即可
	 */}
	<header class="pt-6 lg:pt-8">
		<div class="flex items-center gap-3 sm:gap-4 mb-3">
			{/* 左:eyebrow + count */}
			<div class="shrink-0 flex items-baseline gap-2">
				<span
					class:list={[
						"mono-label",
						"text-[11px] sm:text-xs",
						"leading-none",
						"tracking-[var(--tracking-wider)]",
						"text-[color:var(--color-ink-secondary)]",
						"font-medium",
					]}
				>
					{copy.sectionTitle}
				</span>
			</div>

			{/* 中:分类切换(占据剩余宽度,超出横向滚动) */}
			<BlogCategoryTabs
				listPath={listPath}
				categories={categoriesList}
				activeSlug={activeCatSlug}
				counts={categoryCountsForTabs}
				currentQuery={pageResult.query}
				class="flex-1 min-w-0"
			/>

			{/* 右:搜索框 */}
			<div class="shrink-0 flex items-center">
				<BlogSearchBox
					action={searchAction}
					initialQuery={pageResult.query}
					hiddenFields={{ cat: activeCatSlug }}
				/>
			</div>
		</div>

		{/* 虚线分割(与 SectionHeader 一致的节奏) */}
		<hr
			aria-hidden="true"
			class:list={[
				"border-0 border-t border-dashed",
				"border-[color:var(--color-hairline)]",
				"m-0",
			]}
		/>
	</header>

	{/* ---------- 搜索结果提示行(仅搜索态显示) ---------- */}
	{
		hasQuery && (
			<div
				class:list={[
					"mt-4",
					"flex items-center gap-3",
					"font-[var(--font-mono)]",
					"text-[11px] sm:text-[11.5px]",
					"leading-none",
					"tracking-[var(--tracking-wide)]",
					"text-[color:var(--color-ink-tertiary)]",
				]}
			>
				<span>
					{pageResult.total > 0
						? copy.searchResults(pageResult.total, pageResult.query)
						: copy.searchEmpty(pageResult.query)}
				</span>
				<a
					href={listPath}
					class:list={[
						"underline decoration-dashed underline-offset-2",
						"decoration-[color:var(--color-hairline-strong)]",
						"hover:text-[color:var(--color-ink-primary)]",
						"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
					]}
				>
					{copy.clearSearch}
				</a>
			</div>
		)
	}

	{/* ---------- 文章列表 ---------- */}
	{
		posts.length === 0 ? (
			/* 空状态:搜索无结果 vs 站点无文章,两种情况用同一个视觉容器 */
			<div
				class:list={[
					"mt-8 lg:mt-10 mb-16",
					"flex flex-col items-center justify-center",
					"py-16 lg:py-20",
					"border border-dashed border-[color:var(--color-hairline)]",
					"text-center",
				]}
			>
				<span
					aria-hidden="true"
					class:list={[
						"mono-label",
						"text-[11px]",
						"text-[color:var(--color-ink-muted)]",
						"mb-3",
					]}
				>
					— {hasQuery ? "NO RESULTS" : "EMPTY"} —
				</span>
				<p
					class:list={[
						"text-[color:var(--color-ink-secondary)]",
						"text-[14px]",
						"leading-[1.6]",
					]}
				>
					{hasQuery ? copy.searchEmpty(pageResult.query) : copy.empty}
				</p>
			</div>
		) : (
			<div
				class:list={[
					"mt-6 lg:mt-8 mb-8",
					// 整个列表包在一个虚线边框里,每篇文章用虚线分隔
					"border border-dashed border-[color:var(--color-hairline)]",
					"divide-y divide-dashed divide-[color:var(--color-hairline)]",
				]}
			>
				{/* Featured 优先(仅非搜索态 + 第 1 页) */}
				{featuredRenderable.map(({ vm: post, titleHtml, excerptHtml }) => (
					<PostCard
						href={tp(`/blog/${post.slug}`)}
						title={post.title}
						titleHtml={titleHtml}
						excerpt={post.excerpt}
						excerptHtml={excerptHtml}
						cover={post.cover}
						coverLabel={post.coverLabel}
						authorName={post.authorName ?? undefined}
						categoryName={post.categoryName ?? undefined}
						date={post.date}
						tags={post.tags}
						readingTime={post.readingTime}
						featured
					/>
				))}

				{/* 其余按日期降序(搜索态下所有命中都走这个分支) */}
				{regularRenderable.map(({ vm: post, titleHtml, excerptHtml }) => (
					<PostCard
						href={tp(`/blog/${post.slug}`)}
						title={post.title}
						titleHtml={titleHtml}
						excerpt={post.excerpt}
						excerptHtml={excerptHtml}
						cover={post.cover}
						coverLabel={post.coverLabel}
						authorName={post.authorName ?? undefined}
						categoryName={post.categoryName ?? undefined}
						date={post.date}
						tags={post.tags}
						readingTime={post.readingTime}
					/>
				))}
			</div>
		)
	}

	{/* ---------- 分页 ---------- */}
	{
		pageResult.totalPages > 1 && (
			<div class="mb-16">
				<Pagination
					currentPage={pageResult.page}
					totalPages={pageResult.totalPages}
					totalItems={pageResult.total}
					baseUrl={paginationBaseUrl}
					pageParam="page"
				/>
			</div>
		)
	}
</AppShell>
