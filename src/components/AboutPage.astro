---
/**
 * ============================================================================
 * AboutPage - 关于/社区页共享组件
 * ----------------------------------------------------------------------------
 * 为什么抽成独立组件:
 *   中文 /about 与英文 /en/about 两个入口页面 95% 的逻辑相同,
 *   只有语言推导与少量默认文案不同。本组件负责:
 *     1. 从 Directus 拉取 site_settings / projects 统计(失败时 fallback)
 *     2. 把 Bilingual 字段按当前 lang 解包
 *     3. 展示:ABOUT / IN NUMBERS / JOIN US ON / STACK / CONTACT 分区
 *
 * 视觉参考: better-auth.com 的 /community 页
 *   - 大号数字统计("IN NUMBERS")作为主视觉
 *   - "JOIN US ON" 平台卡片,每张带图标 + 标签 + 数据 + CTA
 *   - 右下角"Shop our merch" 式的额外条目用来挂"友情链接"位
 *   - 整页深度贴合编辑派极简 + Monospace 元素
 *
 * 左栏 meta 字段说明:
 *   - STARS         GitHub 总 star 数
 *   - REPOS         仓库数
 *   - CONTRIBUTORS  贡献者数
 *   - MEMBERS       社区成员(Discord,占位)
 *   - SINCE         建立年份
 * ============================================================================
 */

import AppShell from "@layouts/AppShell.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import MetaRow from "@components/ui/MetaRow.astro";
import {
	getLangFromUrl,
	useTranslations,
} from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import {
	FALLBACK_SITE_SETTINGS,
	FALLBACK_LANGUAGE_STATS,
	listFallbackProjects,
	getFallbackCounts,
	pickLang,
} from "@lib/fallback-data";

/* ----------------------------------------------------------------------------
 * 当前语言 / 翻译工具
 * -------------------------------------------------------------------------- */

const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

/* ----------------------------------------------------------------------------
 * 数据(此页统计值绝大多数来自 fallback:GitHub 实时数据由构建脚本回填)
 * -------------------------------------------------------------------------- */

const settings = FALLBACK_SITE_SETTINGS;
const counts = getFallbackCounts();
const projects = listFallbackProjects();
const languageStats = FALLBACK_LANGUAGE_STATS;

const tagline = pickLang(settings.tagline, lang);
const description = pickLang(settings.description, lang);
const location = pickLang(settings.location, lang);

/* ----------------------------------------------------------------------------
 * 格式化辅助
 * -------------------------------------------------------------------------- */

function formatCount(n: number): string {
	if (n < 1000) return String(n);
	if (n < 10000) return `${(n / 1000).toFixed(1)}k`;
	return `${Math.round(n / 1000)}k`;
}

function formatLarge(n: number): string {
	// 大号数字展示(用于 IN NUMBERS 分区),保留一位小数
	if (n < 1000) return String(n);
	if (n < 1_000_000) return `${(n / 1000).toFixed(n < 10000 ? 2 : 1)}K`;
	return `${(n / 1_000_000).toFixed(1)}M`;
}

/* ----------------------------------------------------------------------------
 * 页面级文案
 * -------------------------------------------------------------------------- */

const COPY = {
	zh: {
		eyebrow: "关于",
		title: "关于 ZerxLab",
		description: description,

		sectionAbout: "ABOUT",
		sectionNumbers: "IN NUMBERS",
		sectionJoin: "JOIN US ON",
		sectionStack: "STACK",
		sectionContact: "CONTACT",

		/* ABOUT 区 */
		aboutBody1:
			"ZerxLab 不是一家公司,也不是一个产品团队。它是一个独立开发者维护的全栈实验室 —— 把业余时间、工程实践和好奇心沉淀为一批可用的开源工具。",
		aboutBody2:
			"这里产出的东西都有一个共同标准:能跑、能测、能用。每个项目都提供基准数据、完整文档,并以 MIT 协议开放源代码。",
		aboutBody3:
			"如果你也相信「细节即品牌、代码即文档」,欢迎通过 Issue、PR 或下方任一渠道加入对话。",

		/* 数字标签 */
		numberGithubStars: "GITHUB STARS",
		numberRepos: "REPOSITORIES",
		numberAurPkgs: "AUR PACKAGES",
		numberContributors: "CONTRIBUTORS",
		numberLabelWeek: "总计",
		numberLabelMaintained: "全部维护中",
		numberLabelOpenSource: "MIT 开源",
		numberLabelCommunity: "社区成员",

		/* JOIN US ON 平台卡片 */
		joinGithub: "GITHUB",
		joinGithubDesc: "所有项目源码、Issue 与 Release 的根据地。",
		joinGithubCta: "前往 GitHub",
		joinGithubLabel: "组织",

		joinAur: "AUR",
		joinAurDesc: "为 Arch Linux 用户维护的预编译包,yay 一行即装。",
		joinAurCta: "浏览 AUR 包",
		joinAurLabel: "包数",

		joinBlog: "BLOG",
		joinBlogDesc: "工程笔记、发布记录与思考,支持 RSS 订阅。",
		joinBlogCta: "阅读博客",
		joinBlogLabel: "文章",

		joinEmail: "EMAIL",
		joinEmailDesc: "合作、咨询、提问都欢迎。工作日 48 小时内回复。",
		joinEmailCta: "发送邮件",
		joinEmailLabel: "回复",
		joinEmailLabelValue: "48h",

		/* STACK */
		stackBody:
			"日常高频使用的技术栈,按语言占比排序。比例来自 GitHub 公开仓库的真实统计。",

		/* CONTACT */
		contactBody:
			"最快的方式是 GitHub Issue 或邮件。我更愿意在公开渠道讨论技术问题,因为其他人也能从对话中受益。",
		contactPrimary: "发送邮件",
		contactSecondary: "在 GitHub 发起讨论",

		/* meta 区 */
		metaStars: "STARS",
		metaRepos: "REPOS",
		metaContributors: "CONTRIBUTORS",
		metaMembers: "MEMBERS",
		metaSince: "SINCE",
		metaLicense: "LICENSE",
	},

	en: {
		eyebrow: "About",
		title: "About ZerxLab",
		description: description,

		sectionAbout: "ABOUT",
		sectionNumbers: "IN NUMBERS",
		sectionJoin: "JOIN US ON",
		sectionStack: "STACK",
		sectionContact: "CONTACT",

		aboutBody1:
			"ZerxLab is not a company or a product team. It is a full-stack laboratory run by a solo developer — distilling side-project hours, engineering practice, and curiosity into a portfolio of open-source tools.",
		aboutBody2:
			"Everything shipped here meets a single bar: it runs, it is benchmarked, it is usable. Every project ships with numbers, docs, and MIT-licensed source.",
		aboutBody3:
			'If you also believe that "details are the brand, code is the docs", join the conversation via an Issue, PR, or any channel below.',

		numberGithubStars: "GITHUB STARS",
		numberRepos: "REPOSITORIES",
		numberAurPkgs: "AUR PACKAGES",
		numberContributors: "CONTRIBUTORS",
		numberLabelWeek: "total",
		numberLabelMaintained: "all maintained",
		numberLabelOpenSource: "MIT licensed",
		numberLabelCommunity: "community",

		joinGithub: "GITHUB",
		joinGithubDesc:
			"Home base for every project's source, issues, and releases.",
		joinGithubCta: "Visit GitHub",
		joinGithubLabel: "Org",

		joinAur: "AUR",
		joinAurDesc:
			"Prebuilt binaries for Arch Linux users, installable with one yay command.",
		joinAurCta: "Browse AUR",
		joinAurLabel: "Packages",

		joinBlog: "BLOG",
		joinBlogDesc:
			"Engineering notes, release logs, and thoughts. RSS ready.",
		joinBlogCta: "Read the blog",
		joinBlogLabel: "Posts",

		joinEmail: "EMAIL",
		joinEmailDesc:
			"Collaboration, questions, or a quick hi — all welcome. Replies within 48h on weekdays.",
		joinEmailCta: "Send email",
		joinEmailLabel: "Reply",
		joinEmailLabelValue: "48h",

		stackBody:
			"Day-to-day stack, ordered by real usage. Percentages from public GitHub repos.",

		contactBody:
			"Fastest path is GitHub Issues or email. I prefer public channels for technical topics so others can benefit from the conversation.",
		contactPrimary: "Send email",
		contactSecondary: "Start a discussion",

		metaStars: "STARS",
		metaRepos: "REPOS",
		metaContributors: "CONTRIBUTORS",
		metaMembers: "MEMBERS",
		metaSince: "SINCE",
		metaLicense: "LICENSE",
	},
} as const;

const C = COPY[lang] ?? COPY.zh;

/* ----------------------------------------------------------------------------
 * JOIN US ON 平台卡片数据
 * ----------------------------------------------------------------------------
 * 静态配置,避免在 JSX 里写太长的条件表达式
 * -------------------------------------------------------------------------- */

interface JoinPlatform {
	key: "github" | "aur" | "blog" | "email";
	eyebrow: string;
	description: string;
	cta: string;
	ctaHref: string;
	external: boolean;
	metricLabel: string;
	metricValue: string;
	icon: "github" | "aur" | "blog" | "email";
}

const joinPlatforms: readonly JoinPlatform[] = [
	{
		key: "github",
		eyebrow: C.joinGithub,
		description: C.joinGithubDesc,
		cta: C.joinGithubCta,
		ctaHref: settings.socialGithub,
		external: true,
		metricLabel: C.joinGithubLabel,
		metricValue: "zerx-lab",
		icon: "github",
	},
	{
		key: "aur",
		eyebrow: C.joinAur,
		description: C.joinAurDesc,
		cta: C.joinAurCta,
		ctaHref: lang === "zh" ? "/aur" : "/en/aur",
		external: false,
		metricLabel: C.joinAurLabel,
		metricValue: String(counts.aurPackages),
		icon: "aur",
	},
	{
		key: "blog",
		eyebrow: C.joinBlog,
		description: C.joinBlogDesc,
		cta: C.joinBlogCta,
		ctaHref: lang === "zh" ? "/blog" : "/en/blog",
		external: false,
		metricLabel: C.joinBlogLabel,
		metricValue: String(counts.posts),
		icon: "blog",
	},
	{
		key: "email",
		eyebrow: C.joinEmail,
		description: C.joinEmailDesc,
		cta: C.joinEmailCta,
		ctaHref: settings.socialEmail
			? `mailto:${settings.socialEmail}`
			: "#",
		external: false,
		metricLabel: C.joinEmailLabel,
		metricValue: C.joinEmailLabelValue,
		icon: "email",
	},
] as const;

/* ----------------------------------------------------------------------------
 * IN NUMBERS 数据条目
 * -------------------------------------------------------------------------- */

interface NumberStat {
	label: string;
	value: string;
	sub: string;
	icon: "star" | "repo" | "package" | "users";
}

const numberStats: readonly NumberStat[] = [
	{
		label: C.numberGithubStars,
		value: formatLarge(counts.totalStars),
		sub: C.numberLabelWeek,
		icon: "star",
	},
	{
		label: C.numberRepos,
		value: String(counts.projects),
		sub: C.numberLabelOpenSource,
		icon: "repo",
	},
	{
		label: C.numberAurPkgs,
		value: String(counts.aurPackages),
		sub: C.numberLabelMaintained,
		icon: "package",
	},
	{
		label: C.numberContributors,
		value: String(settings.contributors),
		sub: C.numberLabelCommunity,
		icon: "users",
	},
] as const;
---

<AppShell
	title={C.title}
	description={C.description}
	eyebrow={C.eyebrow}
	leftTitle={C.title}
	leftDescription={C.description}
>
	{/* ---------- 左栏:社交 ---------- */}
	<Fragment slot="left-social">
		<a
			href={settings.socialGithub}
			target="_blank"
			rel="noopener noreferrer"
			aria-label="GitHub"
			class="transition-colors hover:text-[color:var(--color-ink-primary)]"
		>
			<svg
				width="16"
				height="16"
				viewBox="0 0 24 24"
				fill="currentColor"
				aria-hidden="true"
			>
				<path
					d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.1-.4-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3"
				></path>
			</svg>
		</a>
		{settings.socialEmail && (
			<a
				href={`mailto:${settings.socialEmail}`}
				aria-label="Email"
				class="transition-colors hover:text-[color:var(--color-ink-primary)]"
			>
				<svg
					width="15"
					height="15"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
					<polyline points="22,6 12,13 2,6"></polyline>
				</svg>
			</a>
		)}
		<a
			href="/rss.xml"
			aria-label="RSS"
			class="transition-colors hover:text-[color:var(--color-ink-primary)]"
		>
			<svg
				width="15"
				height="15"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				aria-hidden="true"
			>
				<path d="M4 11a9 9 0 0 1 9 9"></path>
				<path d="M4 4a16 16 0 0 1 16 16"></path>
				<circle cx="5" cy="19" r="1"></circle>
			</svg>
		</a>
	</Fragment>

	{/* ---------- 左栏:Meta ---------- */}
	<Fragment slot="left-meta">
		<MetaRow
			label={C.metaStars}
			value={formatCount(counts.totalStars)}
		/>
		<MetaRow label={C.metaRepos} value={String(counts.projects)} />
		<MetaRow
			label={C.metaContributors}
			value={String(settings.contributors)}
		/>
		<MetaRow
			label={C.metaSince}
			value={String(settings.establishedYear)}
		/>
		<MetaRow
			label={t("meta.location")}
			value={location}
		/>
		<MetaRow label={C.metaLicense} value="MIT" />
	</Fragment>

	{/* ==========================================================================
	 *                            右栏主内容
	 * ========================================================================== */}

	{/* ---------- ABOUT 分区 ---------- */}
	<SectionHeader eyebrow={C.sectionAbout} />

	<div class="mt-6 lg:mt-8 space-y-4 lg:space-y-5">
		<p
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"text-[15px] lg:text-[15.5px]",
				"leading-[1.75]",
				"max-w-[68ch]",
			]}
		>
			<span class="text-[color:var(--color-ink-primary)] font-medium">
				{settings.siteName}
			</span>{" "}
			— {tagline}. {C.aboutBody1}
		</p>

		<p
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"text-[15px] lg:text-[15.5px]",
				"leading-[1.75]",
				"max-w-[68ch]",
			]}
		>
			{C.aboutBody2}
		</p>

		<p
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"text-[15px] lg:text-[15.5px]",
				"leading-[1.75]",
				"max-w-[68ch]",
			]}
		>
			{C.aboutBody3}
		</p>
	</div>

	{/* ---------- IN NUMBERS 分区 ---------- */}
	<SectionHeader eyebrow={C.sectionNumbers} spacious />

	<div
		class:list={[
			"mt-6 lg:mt-8",
			"grid grid-cols-1 sm:grid-cols-2",
			"border border-dashed border-[color:var(--color-hairline)]",
			"divide-x divide-y divide-dashed divide-[color:var(--color-hairline)]",
		]}
	>
		{numberStats.map((stat) => (
			<div
				class:list={[
					"flex flex-col",
					"p-6 lg:p-8",
					"min-h-[140px]",
				]}
			>
				{/* 顶栏:icon + label */}
				<div class="flex items-center gap-2 mb-4">
					<span
						aria-hidden="true"
						class="inline-flex items-center justify-center h-4 w-4 text-[color:var(--color-ink-tertiary)]"
					>
						{stat.icon === "star" && (
							<svg
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="currentColor"
							>
								<path d="M12 .587l3.668 7.568 8.332 1.151-6.064 5.828 1.48 8.279L12 19.446l-7.416 3.967 1.48-8.279L0 9.306l8.332-1.151z" />
							</svg>
						)}
						{stat.icon === "repo" && (
							<svg
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
								<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
							</svg>
						)}
						{stat.icon === "package" && (
							<svg
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
								<polyline points="3.27 6.96 12 12.01 20.73 6.96" />
								<line x1="12" y1="22.08" x2="12" y2="12" />
							</svg>
						)}
						{stat.icon === "users" && (
							<svg
								width="13"
								height="13"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
								<circle cx="9" cy="7" r="4" />
								<path d="M23 21v-2a4 4 0 0 0-3-3.87" />
								<path d="M16 3.13a4 4 0 0 1 0 7.75" />
							</svg>
						)}
					</span>
					<span
						class:list={[
							"mono-label",
							"text-[10.5px] leading-none",
							"tracking-[var(--tracking-wider)]",
							"text-[color:var(--color-ink-tertiary)]",
						]}
					>
						{stat.label}
					</span>
				</div>

				{/* 大数字 */}
				<div
					class:list={[
						"font-medium",
						"text-[color:var(--color-ink-primary)]",
						"tracking-[-0.02em]",
						"leading-none",
						"text-[44px] sm:text-[48px] lg:text-[56px]",
						"tabular-nums",
						"mb-3",
					]}
				>
					{stat.value}
				</div>

				{/* 副标题 */}
				<div
					class:list={[
						"mono-label",
						"text-[10px] leading-none",
						"tracking-[var(--tracking-wide)]",
						"text-[color:var(--color-ink-muted)]",
					]}
				>
					{stat.sub}
				</div>
			</div>
		))}
	</div>

	{/* ---------- JOIN US ON 分区 ---------- */}
	<SectionHeader
		eyebrow={C.sectionJoin}
		count={joinPlatforms.length}
		spacious
	/>

	<div
		class:list={[
			"mt-6 lg:mt-8",
			"grid grid-cols-1 sm:grid-cols-2",
			"border border-dashed border-[color:var(--color-hairline)]",
			"divide-x divide-y divide-dashed divide-[color:var(--color-hairline)]",
		]}
	>
		{joinPlatforms.map((platform) => (
			<div class="flex flex-col p-6 lg:p-7 min-h-[200px]">
				{/* 顶栏:icon + eyebrow + 右侧数据 */}
				<div class="flex items-center gap-3 mb-4">
					<span
						aria-hidden="true"
						class:list={[
							"inline-flex items-center justify-center",
							"h-8 w-8",
							"bg-[color:var(--color-paper-muted)]",
							"border border-[color:var(--color-hairline)]",
							"rounded-[var(--radius-sm)]",
							"text-[color:var(--color-ink-primary)]",
						]}
					>
						{platform.icon === "github" && (
							<svg
								width="15"
								height="15"
								viewBox="0 0 24 24"
								fill="currentColor"
							>
								<path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1-.7.1-.7.1-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 0-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-6 0-1.2.5-2.3 1.3-3.1-.1-.4-.6-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.7 1.6.2 2.8.1 3.2.8.8 1.3 1.9 1.3 3.1 0 4.6-2.8 5.6-5.5 5.9.5.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 12 .3" />
							</svg>
						)}
						{platform.icon === "aur" && (
							<svg
								width="15"
								height="15"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
								<polyline points="3.27 6.96 12 12.01 20.73 6.96" />
								<line x1="12" y1="22.08" x2="12" y2="12" />
							</svg>
						)}
						{platform.icon === "blog" && (
							<svg
								width="15"
								height="15"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
								<polyline points="14 2 14 8 20 8" />
								<line x1="16" y1="13" x2="8" y2="13" />
								<line x1="16" y1="17" x2="8" y2="17" />
								<polyline points="10 9 9 9 8 9" />
							</svg>
						)}
						{platform.icon === "email" && (
							<svg
								width="15"
								height="15"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							>
								<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
								<polyline points="22,6 12,13 2,6" />
							</svg>
						)}
					</span>

					<span
						class:list={[
							"mono-label",
							"text-[11px] leading-none",
							"tracking-[var(--tracking-wider)]",
							"text-[color:var(--color-ink-primary)]",
							"font-semibold",
						]}
					>
						{platform.eyebrow}
					</span>

					<span
						class:list={[
							"ml-auto",
							"inline-flex flex-col items-end gap-0.5",
						]}
					>
						<span
							class:list={[
								"mono-label",
								"text-[9px] leading-none",
								"tracking-[var(--tracking-wider)]",
								"text-[color:var(--color-ink-muted)]",
							]}
						>
							{platform.metricLabel}
						</span>
						<span
							class:list={[
								"font-[var(--font-mono)]",
								"text-[13px] leading-none",
								"text-[color:var(--color-ink-secondary)]",
								"font-semibold",
								"tabular-nums",
								"truncate max-w-[14ch]",
							]}
						>
							{platform.metricValue}
						</span>
					</span>
				</div>

				{/* 描述 */}
				<p
					class:list={[
						"text-[color:var(--color-ink-secondary)]",
						"text-[13.5px] sm:text-[14px]",
						"leading-[1.6]",
						"mb-5",
						"flex-1",
					]}
				>
					{platform.description}
				</p>

				{/* CTA 按钮(满宽) */}
				<a
					href={platform.ctaHref}
					target={platform.external ? "_blank" : undefined}
					rel={platform.external ? "noopener noreferrer" : undefined}
					class:list={[
						"group",
						"inline-flex items-center justify-center gap-2",
						"w-full",
						"h-9",
						"border border-[color:var(--color-hairline-strong)]",
						"rounded-[var(--radius-sm)]",
						"mono-label",
						"text-[11px] leading-none",
						"tracking-[var(--tracking-wider)]",
						"text-[color:var(--color-ink-primary)]",
						"hover:bg-[color:var(--color-ink-primary)]",
						"hover:text-[color:var(--color-paper)]",
						"hover:border-[color:var(--color-ink-primary)]",
						"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
					]}
				>
					<span>{platform.cta}</span>
					<svg
						aria-hidden="true"
						width="10"
						height="10"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5"
						stroke-linecap="round"
						stroke-linejoin="round"
						class:list={[
							"shrink-0",
							"transition-transform duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
							platform.external
								? "group-hover:translate-x-[1px] group-hover:-translate-y-[1px]"
								: "group-hover:translate-x-[2px]",
						]}
					>
						{platform.external ? (
							<>
								<path d="M7 17L17 7" />
								<path d="M8 7h9v9" />
							</>
						) : (
							<>
								<path d="M5 12h14" />
								<path d="m12 5 7 7-7 7" />
							</>
						)}
					</svg>
				</a>
			</div>
		))}
	</div>

	{/* ---------- STACK 分区(语言占比条) ---------- */}
	<SectionHeader eyebrow={C.sectionStack} spacious />

	<div class="mt-6 lg:mt-8">
		<p
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"text-[14px]",
				"leading-[1.65]",
				"max-w-[68ch]",
				"mb-6",
			]}
		>
			{C.stackBody}
		</p>

		{/* 横向语言占比条 */}
		<div
			class:list={[
				"w-full",
				"h-2.5",
				"flex overflow-hidden",
				"border border-[color:var(--color-hairline)]",
				"rounded-[var(--radius-sm)]",
				"bg-[color:var(--color-paper-muted)]",
			]}
			role="img"
			aria-label={lang === "zh" ? "语言占比条" : "Language distribution"}
		>
			{languageStats.map((lg) => (
				<span
					style={`width: ${lg.percent}%; background-color: ${lg.color};`}
					class="h-full inline-block"
					title={`${lg.name}: ${lg.percent}%`}
				></span>
			))}
		</div>

		{/* 图例 */}
		<ul
			class:list={[
				"mt-4",
				"grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4",
				"gap-x-4 gap-y-2",
				"list-none m-0 p-0",
			]}
		>
			{languageStats.map((lg) => (
				<li class="flex items-center gap-2">
					<span
						aria-hidden="true"
						class="inline-block h-2 w-2 rounded-full shrink-0"
						style={`background-color: ${lg.color};`}
					></span>
					<span
						class:list={[
							"font-[var(--font-mono)]",
							"text-[11px] leading-none",
							"text-[color:var(--color-ink-secondary)]",
							"truncate",
						]}
					>
						{lg.name}
					</span>
					<span
						class:list={[
							"ml-auto",
							"font-[var(--font-mono)]",
							"text-[11px] leading-none",
							"text-[color:var(--color-ink-muted)]",
							"tabular-nums",
						]}
					>
						{lg.percent.toFixed(1)}%
					</span>
				</li>
			))}
		</ul>
	</div>

	{/* ---------- CONTACT 分区 ---------- */}
	<SectionHeader eyebrow={C.sectionContact} spacious />

	<div
		class:list={[
			"mt-6 lg:mt-8 mb-16",
			"border border-dashed border-[color:var(--color-hairline)]",
			"bg-[color:var(--color-paper-muted)]/30",
			"px-5 sm:px-6 lg:px-8 py-6 lg:py-8",
		]}
	>
		<p
			class:list={[
				"text-[color:var(--color-ink-secondary)]",
				"text-[14.5px]",
				"leading-[1.7]",
				"max-w-[64ch]",
				"mb-5",
			]}
		>
			{C.contactBody}
		</p>

		<div class="flex flex-wrap items-center gap-2">
			{settings.socialEmail && (
				<a
					href={`mailto:${settings.socialEmail}`}
					class:list={[
						"inline-flex items-center justify-center gap-2",
						"h-9 px-4",
						"bg-[color:var(--color-ink-primary)]",
						"text-[color:var(--color-paper)]",
						"text-[12px] font-medium",
						"tracking-[var(--tracking-wide)]",
						"rounded-[var(--radius-sm)]",
						"hover:opacity-85",
						"transition-opacity duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
						"whitespace-nowrap",
					]}
				>
					<svg
						aria-hidden="true"
						width="12"
						height="12"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
						<polyline points="22,6 12,13 2,6" />
					</svg>
					{C.contactPrimary}
				</a>
			)}

			<a
				href={`${settings.socialGithub}/zerx-lab-website/discussions`}
				target="_blank"
				rel="noopener noreferrer"
				class:list={[
					"inline-flex items-center justify-center gap-2",
					"h-9 px-4",
					"border border-[color:var(--color-hairline-strong)]",
					"text-[color:var(--color-ink-primary)]",
					"text-[12px] font-medium",
					"tracking-[var(--tracking-wide)]",
					"rounded-[var(--radius-sm)]",
					"hover:bg-[color:var(--color-paper-muted)]",
					"transition-colors duration-[var(--duration-fast)] ease-[var(--ease-standard)]",
					"whitespace-nowrap",
				]}
			>
				{C.contactSecondary}
				<svg
					aria-hidden="true"
					width="10"
					height="10"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2.5"
					stroke-linecap="round"
					stroke-linejoin="round"
				>
					<path d="M7 17L17 7" />
					<path d="M8 7h9v9" />
				</svg>
			</a>
		</div>

		{/* 邮件地址以 Monospace 显示,方便复制 */}
		{settings.socialEmail && (
			<div
				class:list={[
					"mt-5 pt-4",
					"border-t border-dashed border-[color:var(--color-hairline)]",
					"flex items-center gap-3 flex-wrap",
				]}
			>
				<span
					class:list={[
						"mono-label",
						"text-[10px] leading-none",
						"text-[color:var(--color-ink-muted)]",
					]}
				>
					EMAIL
				</span>
				<code
					class:list={[
						"font-[var(--font-mono)]",
						"text-[13px] leading-none",
						"text-[color:var(--color-ink-primary)]",
						"bg-transparent border-0 p-0",
						"select-all",
					]}
				>
					{settings.socialEmail}
				</code>
			</div>
		)}
	</div>
</AppShell>
