{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@i18n/*": ["./src/i18n/*"],
      "@styles/*": ["./src/styles/*"],
    },
    "types": ["astro/client"],
    "verbatimModuleSyntax": true,
    "allowJs": false,
  },
  "include": [".astro/types.d.ts", "**/*", "scripts/**/*"],
  "exclude": ["dist", "node_modules", ".astro"],
}
