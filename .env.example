# ============================================================================
# ZerxLab Website - 环境变量模板
# ============================================================================
# 使用说明:
#   1. 将此文件复制为 .env (本地开发) 或 .env.production (生产构建)
#   2. 填入真实值后保存
#   3. .env 已加入 .gitignore,不会被提交到仓库
# ============================================================================


# ---------- Directus 后端 ----------

# Directus 实例地址(生产环境务必使用 https)
DIRECTUS_URL=https://directus.zerx.dev

# Admin 读写 Token
# - 用途: 仅用于本地 bootstrap/seed 脚本 (建表、写种子数据、schema 迁移)
# - 在 Directus 后台: Users → Admin User → Token 字段生成
# - 安全级别: 高危,拥有全部数据库写权限,绝不能泄露
# - 不要用于生产站点构建
DIRECTUS_ADMIN_TOKEN=

# 只读 Token
# - 用途: Astro 构建时从 Directus 拉取已发布内容 (生产/CI)
# - 由 `bun run bootstrap` 脚本自动创建,创建后脚本会输出 token,手动粘贴到此处
# - 绑定角色: Website Public Read (只能 GET published 内容)
# - 安全级别: 中,即使泄露也只能读取公开内容
DIRECTUS_READ_TOKEN=


# ---------- 站点 ----------

# 站点公开 URL,用于生成 sitemap / RSS / OG meta 的绝对地址
# 本地开发可留默认,生产部署时设置为真实域名
SITE_URL=https://zerx.dev


# ---------- 可选:构建时数据源 ----------

# GitHub Personal Access Token (可选)
# - 用途: 构建时拉取 zerx-lab 组织的仓库 stars/forks 等实时数据
# - 权限: 只需要 public_repo 读权限
# - 未设置时会降级使用 Directus 里手工维护的数值
# GITHUB_TOKEN=


# ---------- Astro 运行时(一般不用改) ----------

# 开发服务器端口
# PORT=4321
